@model List<Dinacem.Models.Solicitud>

@{
    ViewData["Title"] = "Mis Solicitudes";
    Layout = "~/Views/Shared/_LayoutEmpleado.cshtml";
}

<div class="container mt-4">

    <div class="d-flex justify-content-between align-items-center mb-3">
        <h3>Mis Solicitudes de Viáticos</h3>

        <a asp-controller="Solicitud"
           asp-action="Create"
           class="btn btn-primary">
            Nueva Solicitud
        </a>
    </div>

    @if (TempData["mensaje"] != null)
    {
        <div class="alert alert-success">
            @TempData["mensaje"]
        </div>
    }

    @if (TempData["error"] != null)
    {
        <div class="alert alert-danger">
            @TempData["error"]
        </div>
    }

    <table class="table table-bordered table-hover align-middle">
        <thead class="table-dark">
            <tr>
                <th>Fecha</th>
                <th>Inicio</th>
                <th>Fin</th>
                <th>Destino</th>
                <th>Motivo</th>
                <th>Monto</th>
                <th>Estado</th>
                <th>Observaciones</th>
            </tr>
        </thead>

        <tbody>
            @if (Model != null && Model.Any())
            {
                foreach (var item in Model)
                {
                    <tr>
                        <td>@item.Fecha.ToString("dd/MM/yyyy")</td>
                        <td>@item.FechaInicio.ToString("dd/MM/yyyy")</td>
                        <td>@item.FechaFin.ToString("dd/MM/yyyy")</td>
                        <td>@item.Destino</td>
                        <td>@item.Motivo</td>
                        <td>S/ @item.Monto.ToString("N2")</td>
                        <td>
                            @if (item.IdEstadoSolicitud == 1)
                            {
                                <span class="badge bg-warning text-dark">Pendiente</span>
                            }
                            else if (item.IdEstadoSolicitud == 2)
                            {
                                <span class="badge bg-success">Aprobada</span>
                            }
                            else if (item.IdEstadoSolicitud == 3)
                            {
                                <span class="badge bg-danger">Rechazada</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">
                                    @(item.EstadoSolicitud?.Nombre ?? "Sin estado")
                                </span>
                            }
                        </td>
                        <td>
                            @(string.IsNullOrWhiteSpace(item.Observaciones) ? "-" : item.Observaciones)
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="8" class="text-center text-muted">
                        No tienes solicitudes registradas.
                    </td>
                </tr>
            }
        </tbody>
    </table>

    <a asp-controller="Empleado"
       asp-action="Index"
       class="btn btn-secondary">
        Volver
    </a>

</div>