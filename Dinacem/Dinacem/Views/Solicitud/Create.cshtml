@model Dinacem.Models.Solicitud

@{
    ViewData["Title"] = "Nueva Solicitud de Viáticos";
    Layout = "~/Views/Shared/_LayoutEmpleado.cshtml";
}

<style>
    .page-wrapper {
        width: 100%;
        max-width: 1100px;
        margin: 0 auto;
    }

    .page-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 16px;
        padding: 22px;
        margin-bottom: 22px;
        background: #ffffff;
        border: 1px solid #e2e8f0;
        border-radius: 16px;
        box-shadow: 0 5px 18px rgba(15, 23, 42, .05);
    }

    .page-title {
        margin: 0 0 5px;
        color: #0f172a;
        font-size: 28px;
        font-weight: 800;
    }

    .page-description {
        margin: 0;
        color: #64748b;
        font-size: 14px;
    }

    .form-card {
        background: #ffffff;
        border: 1px solid #dbe1ea;
        border-radius: 16px;
        box-shadow: 0 5px 18px rgba(15, 23, 42, .06);
        overflow: hidden;
    }

    .form-card-header {
        padding: 18px 22px;
        color: #ffffff;
        background: #0d6efd;
        font-size: 18px;
        font-weight: 800;
    }

    .form-card-body {
        padding: 24px;
    }

    .form-label {
        color: #334155;
        font-size: 13px;
        font-weight: 700;
    }

    .form-control {
        min-height: 44px;
    }

    textarea.form-control {
        min-height: 120px;
    }

    .action-buttons {
        display: flex;
        justify-content: flex-end;
        flex-wrap: wrap;
        gap: 10px;
        margin-top: 24px;
    }

    .validation-summary-valid {
        display: none;
    }

    @@media (max-width: 767.98px) {
        .page-header {
            flex-direction: column;
            align-items: flex-start;
            padding: 18px;
        }

            .page-header .btn {
                width: 100%;
            }

        .page-title {
            font-size: 23px;
        }

        .form-card-body {
            padding: 17px;
        }

        .action-buttons {
            display: grid;
            grid-template-columns: 1fr;
        }

            .action-buttons .btn {
                width: 100%;
            }
    }
</style>

<div class="page-wrapper">

    <!-- La barra del empleado se carga desde _LayoutEmpleado.cshtml -->

    <div class="page-header">
        <div>
            <h1 class="page-title">
                <i class="bi bi-file-earmark-plus me-2"></i>
                Nueva Solicitud de Viáticos
            </h1>

            <p class="page-description">
                Complete los datos del viaje y envíe la solicitud para aprobación.
            </p>
        </div>

        <a asp-controller="Empleado"
           asp-action="Index"
           class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left"></i>
            Volver al panel
        </a>
    </div>

    @if (TempData["mensaje"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">
            @TempData["mensaje"]

            <button type="button"
                    class="btn-close"
                    data-bs-dismiss="alert"
                    aria-label="Cerrar">
            </button>
        </div>
    }

    @if (TempData["error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show">
            @Html.Raw(TempData["error"])

            <button type="button"
                    class="btn-close"
                    data-bs-dismiss="alert"
                    aria-label="Cerrar">
            </button>
        </div>
    }

    <div class="form-card">
        <div class="form-card-header">
            <i class="bi bi-card-checklist me-2"></i>
            Datos de la solicitud
        </div>

        <div class="form-card-body">
            <form asp-controller="Solicitud"
                  asp-action="Create"
                  method="post">

                <div asp-validation-summary="ModelOnly"
                     class="alert alert-danger"></div>

                <div class="row g-3">
                    <div class="col-12 col-md-6">
                        <label asp-for="FechaInicio"
                               class="form-label">
                            Fecha de inicio
                        </label>

                        <input asp-for="FechaInicio"
                               type="date"
                               class="form-control"
                               required />

                        <span asp-validation-for="FechaInicio"
                              class="text-danger small"></span>
                    </div>

                    <div class="col-12 col-md-6">
                        <label asp-for="FechaFin"
                               class="form-label">
                            Fecha de fin
                        </label>

                        <input asp-for="FechaFin"
                               type="date"
                               class="form-control"
                               required />

                        <span asp-validation-for="FechaFin"
                              class="text-danger small"></span>
                    </div>

                    <div class="col-12">
                        <label asp-for="Destino"
                               class="form-label">
                            Destino
                        </label>

                        <input asp-for="Destino"
                               class="form-control"
                               maxlength="200"
                               placeholder="Ejemplo: Lima"
                               required />

                        <span asp-validation-for="Destino"
                              class="text-danger small"></span>
                    </div>

                    <div class="col-12">
                        <label asp-for="Motivo"
                               class="form-label">
                            Motivo del viaje
                        </label>

                        <textarea asp-for="Motivo"
                                  class="form-control"
                                  rows="5"
                                  maxlength="500"
                                  placeholder="Describa el motivo del viaje"
                                  required></textarea>

                        <span asp-validation-for="Motivo"
                              class="text-danger small"></span>
                    </div>

                    <div class="col-12 col-md-6">
                        <label asp-for="Monto"
                               class="form-label">
                            Monto solicitado (S/)
                        </label>

                        <div class="input-group">
                            <span class="input-group-text">S/</span>

                            <input asp-for="Monto"
                                   type="number"
                                   min="0.01"
                                   step="0.01"
                                   class="form-control"
                                   placeholder="0.00"
                                   required />
                        </div>

                        <span asp-validation-for="Monto"
                              class="text-danger small"></span>
                    </div>
                </div>

                <div class="action-buttons">
                    <a asp-controller="Solicitud"
                       asp-action="MisSolicitudes"
                       class="btn btn-outline-secondary">
                        <i class="bi bi-arrow-left"></i>
                        Regresar
                    </a>

                    <button type="submit"
                            class="btn btn-primary">
                        <i class="bi bi-send-fill"></i>
                        Enviar solicitud
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>
