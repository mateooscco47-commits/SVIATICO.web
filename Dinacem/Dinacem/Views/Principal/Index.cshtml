@{
    ViewData["Title"] = "Dashboard Administrador";
    Layout = null;
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <title>DINACEM - Administrador</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

    <style>
        body {
            background: #f4f6f9;
        }

        .sidebar-title {
            font-size: 22px;
            font-weight: bold;
            color: #0d6efd;
        }

        .card-option {
            border: none;
            border-radius: 15px;
            transition: 0.3s;
            cursor: pointer;
        }

        .card-option:hover {
            transform: scale(1.05);
            box-shadow: 0 10px 20px rgba(0,0,0,0.15);
        }

        .icon-box {
            font-size: 40px;
            color: #0d6efd;
        }
    </style>
</head>

<body>

    <div class="container py-5">

        <!-- Encabezado -->
        <div class="text-center mb-5">
            <h2 class="sidebar-title">DINACEM - PANEL ADMINISTRADOR</h2>
            <p class="text-muted">Sistema de Gestión de Viáticos</p>
        </div>

        <!-- Opciones -->
        <div class="row g-4">

            <!-- Usuarios -->
            <div class="col-md-3">
                <div class="card card-option text-center p-4 shadow-sm">
                    <div class="icon-box mb-3">
                        👤
                    </div>
                    <h5>Gestión de Usuarios</h5>
                    <p class="text-muted">Administrar empleados y roles</p>
                    <a href="/Usuario/Index" class="btn btn-primary w-100">Entrar</a>
                </div>
            </div>

            <!-- Solicitudes -->
            <div class="col-md-3">
                <div class="card card-option text-center p-4 shadow-sm">
                    <div class="icon-box mb-3">
                        📄
                    </div>
                    <h5>Solicitudes</h5>
                    <p class="text-muted">Aprobación de viáticos</p>
                    <a href="/Solicitud/Index" class="btn btn-primary w-100">Entrar</a>
                </div>
            </div>

            <!-- Rendiciones -->
            <div class="col-md-3">
                <div class="card card-option text-center p-4 shadow-sm">
                    <div class="icon-box mb-3">
                        💰
                    </div>
                    <h5>Rendiciones</h5>
                    <p class="text-muted">Revisión de gastos</p>
                    <a href="/Rendicion/Index" class="btn btn-primary w-100">Entrar</a>
                </div>
            </div>

            <!-- Gastos -->
            <div class="col-md-3">
                <div class="card card-option text-center p-4 shadow-sm">
                    <div class="icon-box mb-3">
                        🧾
                    </div>
                    <h5>Gastos</h5>
                    <p class="text-muted">Registro de comprobantes</p>
                    <a href="/Gasto/Index" class="btn btn-primary w-100">Entrar</a>
                </div>
            </div>

        </div>

        <!-- Segunda fila -->
        <div class="row g-4 mt-3">

            <!-- Reportes -->
            <div class="col-md-3">
                <div class="card card-option text-center p-4 shadow-sm">
                    <div class="icon-box mb-3">
                        📊
                    </div>
                    <h5>Reportes</h5>
                    <p class="text-muted">Estadísticas del sistema</p>
                    <a href="#" class="btn btn-primary w-100">Entrar</a>
                </div>
            </div>

            <!-- Logout -->
            <div class="col-md-3">
                <div class="card card-option text-center p-4 shadow-sm">
                    <div class="icon-box mb-3">
                        🚪
                    </div>
                    <h5>Salir</h5>
                    <p class="text-muted">Cerrar sesión</p>
                    <a href="/Home/Logout" class="btn btn-danger w-100">Salir</a>
                </div>
            </div>

        </div>

    </div>

</body>
</html>