@{
    ViewData["Title"] = "Dashboard Administrador";
    Layout = "~/Views/Shared/_LayoutAdministrador.cshtml";
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <title>DINACEM - Administrador</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

    <style>
        body {
            background: #f4f6f9;
        }

        .sidebar-title {
            font-size: 24px;
            font-weight: bold;
            color: #0d6efd;
        }

        .card-option {
            border: none;
            border-radius: 15px;
            transition: 0.3s;
            cursor: pointer;
            min-height: 230px;
        }

            .card-option:hover {
                transform: scale(1.04);
                box-shadow: 0 10px 20px rgba(0,0,0,0.15);
            }

        .icon-box {
            font-size: 42px;
            color: #0d6efd;
        }
    </style>
</head>

<body>

    <div class="container py-5">

        <div class="text-center mb-5">
            <h2 class="sidebar-title">DINACEM - PANEL ADMINISTRADOR</h2>
            <p class="text-muted">Sistema de Gestión de Viáticos</p>
        </div>

        <div class="row g-4">

            <div class="col-md-3">
                <div class="card card-option text-center p-4 shadow-sm">
                    <div class="icon-box mb-3">👤</div>
                    <h5>Gestión de Usuarios</h5>
                    <p class="text-muted">Administrar empleados y roles</p>
                    <a asp-controller="Usuario" asp-action="Index" class="btn btn-primary w-100">Entrar</a>
                </div>
            </div>

            <div class="col-md-3">
                <div class="card card-option text-center p-4 shadow-sm">
                    <div class="icon-box mb-3">📄</div>
                    <h5>Solicitudes</h5>
                    <p class="text-muted">Aprobar o rechazar viáticos</p>
                    <a asp-controller="Solicitud" asp-action="Index" class="btn btn-primary w-100">Entrar</a>
                </div>
            </div>

            <div class="col-md-3">
                <div class="card card-option text-center p-4 shadow-sm">
                    <div class="icon-box mb-3">💰</div>
                    <h5>Rendiciones</h5>
                    <p class="text-muted">Revisar gastos enviados</p>
                    <a asp-controller="Rendicion" asp-action="IndexAdmin" class="btn btn-primary w-100">Entrar</a>
                </div>
            </div>

            <div class="col-md-3">
                <div class="card card-option text-center p-4 shadow-sm">
                    <div class="icon-box mb-3">📊</div>
                    <h5>Reportes</h5>
                    <p class="text-muted">Estadísticas del sistema</p>
                    <a href="#" class="btn btn-primary w-100">Entrar</a>
                </div>
            </div>

        </div>

        <div class="row g-4 mt-3">
            <div class="col-md-3">
                <div class="card card-option text-center p-4 shadow-sm">
                    <div class="icon-box mb-3">🚪</div>
                    <h5>Salir</h5>
                    <p class="text-muted">Cerrar sesión</p>
                    <a asp-controller="Home" asp-action="Logout" class="btn btn-danger w-100">Salir</a>
                </div>
            </div>
        </div>

    </div>

</body>
</html>