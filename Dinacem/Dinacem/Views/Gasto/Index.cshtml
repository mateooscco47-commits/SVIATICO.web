@model List<Dinacem.Models.Gasto>

@{
    ViewData["Title"] = "Rendición de Gastos";
    Layout = "~/Views/Shared/_LayoutEmpleado.cshtml";

    var rendicion = ViewBag.Rendicion as Dinacem.Models.Rendicion;
    var tiposGasto = ViewBag.TiposGasto as List<Dinacem.Models.TipoGasto>;
    var tiposComprobante = ViewBag.TiposComprobante as List<Dinacem.Models.TipoComprobante>;

    var montoAprobado = rendicion?.Solicitud?.Monto ?? 0;
    var totalValorVenta = Model?.Sum(x => x.ValorVenta) ?? 0;
    var totalIgv = Model?.Sum(x => x.IGV) ?? 0;
    var totalRendido = rendicion?.Total ?? 0;
    var saldoDisponible = rendicion?.Saldo ?? 0;
    var devolucion = ViewBag.DevolucionSaldo as Dinacem.Models.DevolucionSaldo;
}

<style>
    .page-wrapper {
        width: 100%;
        max-width: 1650px;
        margin: 0 auto;
    }

    .page-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 16px;
        padding: 22px;
        margin-bottom: 22px;
        background: #ffffff;
        border: 1px solid #e2e8f0;
        border-radius: 16px;
        box-shadow: 0 5px 18px rgba(15, 23, 42, .05);
    }

    .page-title {
        margin: 0 0 5px;
        color: #0f172a;
        font-size: 28px;
        font-weight: 800;
    }

    .page-description {
        margin: 0;
        color: #64748b;
        font-size: 14px;
    }

    .panel {
        background: white;
        border: 1px solid #dbe1ea;
        border-radius: 12px;
        box-shadow: 0 4px 12px rgba(15, 23, 42, .04);
    }

    .panel-header {
        padding: 18px 22px;
        border-bottom: 1px solid #e5e7eb;
        font-weight: 800;
        color: #0d6efd;
    }

    .panel-body {
        padding: 20px;
    }

    .small-label {
        font-size: 12px;
        font-weight: 700;
        color: #64748b;
        text-transform: uppercase;
    }

    .summary-card {
        border: 1px solid #dbe1ea;
        border-radius: 10px;
        padding: 16px;
        background: #fff;
    }

    .summary-value {
        font-size: 22px;
        font-weight: 800;
        color: #0f172a;
    }

    .summary-blue {
        color: #0d6efd;
    }

    .summary-green {
        color: #198754;
    }

    .summary-orange {
        color: #f59e0b;
    }

    .table th {
        font-size: 12px;
        color: #64748b;
        text-transform: uppercase;
    }

    .form-label {
        font-size: 13px;
        font-weight: 600;
        color: #334155;
    }

    .btn-dark-custom {
        background: #0f172a;
        color: white;
        font-weight: 700;
        height: 44px;
    }

        .btn-dark-custom:hover {
            background: #111827;
            color: white;
        }

    .badge-gasto {
        background: #dcfce7;
        color: #166534;
        border: 1px solid #86efac;
        padding: 5px 10px;
        border-radius: 6px;
    }

    .devolucion-ok {
        border-left: 5px solid #198754;
    }

    .devolucion-pendiente {
        border-left: 5px solid #ffc107;
    }

    .tax-summary {
        background: #f8fafc;
        border: 1px solid #dbe1ea;
        border-radius: 10px;
        padding: 14px;
    }

        .tax-summary strong {
            font-size: 18px;
        }

    .table-gastos {
        min-width: 1050px;
    }

    .table-info {
        min-width: 520px;
    }

    .mobile-hint {
        display: none;
        margin-top: 5px;
        color: #64748b;
        font-size: 12px;
        font-weight: 400;
    }

    .action-row {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
    }

    @@media (max-width: 1199.98px) {
        .page-header {
            align-items: flex-start;
            flex-direction: column;
        }

            .page-header .btn {
                width: 100%;
            }
    }

    @@media (max-width: 991.98px) {
        .panel-body {
            padding: 17px;
        }

        .mobile-hint {
            display: block;
        }

        .btn-dark-custom {
            width: 100%;
        }
    }

    @@media (max-width: 767.98px) {
        .page-header {
            padding: 18px;
            border-radius: 13px;
        }

        .page-title {
            font-size: 23px;
        }

        .panel {
            border-radius: 13px;
        }

        .panel-header {
            padding: 15px 16px;
        }

        .panel-body {
            padding: 14px;
        }

        .summary-value {
            font-size: 19px;
        }

        .tax-summary {
            padding: 12px;
        }

        .input-group > .btn {
            width: 100%;
            margin-top: 8px;
            border-radius: 8px !important;
        }

        .input-group > .form-control {
            width: 100%;
            border-radius: 8px !important;
        }

        .action-row {
            display: grid;
            grid-template-columns: 1fr;
        }

            .action-row .btn,
            .action-row form,
            .action-row form .btn {
                width: 100%;
            }
    }
</style>

<div class="page-wrapper">

    <!-- La barra de navegación del empleado se carga desde _LayoutEmpleado.cshtml -->

    <div class="page-header">

        <div>
            <h1 class="page-title">
                <i class="bi bi-receipt-cutoff me-2"></i>
                Rendición de Gastos
            </h1>

            <p class="page-description">
                Registre sus gastos, consulte el saldo y envíe la rendición para revisión.
            </p>
        </div>

        <a asp-controller="Rendicion"
           asp-action="Index"
           class="btn btn-outline-secondary">

            <i class="bi bi-arrow-left"></i>
            Volver a rendiciones

        </a>

    </div>

    @if (TempData["mensaje"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">
            @TempData["mensaje"]

            <button type="button"
                    class="btn-close"
                    data-bs-dismiss="alert"
                    aria-label="Cerrar">
            </button>
        </div>
    }

    @if (TempData["error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show">
            @Html.Raw(TempData["error"])

            <button type="button"
                    class="btn-close"
                    data-bs-dismiss="alert"
                    aria-label="Cerrar">
            </button>
        </div>
    }

    <div class="row g-4">

        <div class="col-lg-8">

            <div class="panel mb-4">
                <div class="panel-header">
                    GASTOS REGISTRADOS
                    <div class="text-muted fw-normal mt-1">
                        Listado de gastos de la rendición actual
                    </div>

                    <div class="mobile-hint">
                        Deslice horizontalmente para ver todas las columnas.
                    </div>
                </div>

                <div class="panel-body p-0">

                    <div class="table-responsive">

                        <table class="table table-gastos align-middle mb-0">
                            <thead>
                                <tr>
                                    <th>Fecha</th>
                                    <th>Tipo</th>
                                    <th>Comprobante</th>
                                    <th>Detalle</th>
                                    <th>Base</th>
                                    <th>IGV</th>
                                    <th>Total</th>
                                    <th>Acciones</th>
                                </tr>
                            </thead>

                            <tbody>
                                @if (Model != null && Model.Any())
                                {
                                    foreach (var item in Model)
                                    {
                                        <tr>
                                            <td>@item.Fecha.ToString("dd/MM/yyyy")</td>

                                            <td>
                                                <span class="badge-gasto">
                                                    @item.TipoGasto?.Nombre
                                                </span>
                                            </td>

                                            <td>
                                                @item.TipoComprobante?.Nombre
                                                <br />
                                                <span class="text-muted">
                                                    @item.Serie - @item.Numero
                                                </span>
                                            </td>

                                            <td>@item.Detalle</td>

                                            <td>
                                                S/ @item.ValorVenta.ToString("N2")

                                                @if (item.ExoneracionIGV)
                                                {
                                                    <br />
                                                    <span class="badge bg-info text-dark">
                                                        Exonerado
                                                    </span>
                                                }
                                            </td>

                                            <td>S/ @item.IGV.ToString("N2")</td>

                                            <td>
                                                <strong>
                                                    S/ @item.MontoTotal.ToString("N2")
                                                </strong>
                                            </td>

                                            <td>
                                                @if (rendicion?.IdEstadoRendicion == 1)
                                                {
                                                    <form asp-controller="Gasto"
                                                          asp-action="Delete"
                                                          method="post"
                                                          class="d-inline">

                                                        <input type="hidden"
                                                               name="id"
                                                               value="@item.IdGasto" />

                                                        <input type="hidden"
                                                               name="idRendicion"
                                                               value="@rendicion.IdRendicion" />

                                                        <button class="btn btn-outline-danger btn-sm"
                                                                onclick="return confirm('¿Eliminar este gasto?');">
                                                            Eliminar
                                                        </button>
                                                    </form>
                                                }
                                                else
                                                {
                                                    <span class="text-muted">Bloqueado</span>
                                                }
                                            </td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr>
                                        <td colspan="8" class="text-center text-muted py-4">
                                            Aún no hay gastos registrados.
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>

                    </div>

                    <div class="p-3 border-top">
                        Mostrando @(Model?.Count ?? 0) gasto(s)
                    </div>

                    <div class="row g-3 p-3">
                        <div class="col-md-4">
                            <div class="summary-card text-center">
                                <div class="small-label">Valor de venta</div>
                                <div class="summary-value">
                                    S/ @totalValorVenta.ToString("N2")
                                </div>
                            </div>
                        </div>

                        <div class="col-md-4">
                            <div class="summary-card text-center">
                                <div class="small-label">Total IGV</div>
                                <div class="summary-value">
                                    S/ @totalIgv.ToString("N2")
                                </div>
                            </div>
                        </div>

                        <div class="col-md-4">
                            <div class="summary-card text-center">
                                <div class="small-label summary-blue">Total rendido</div>
                                <div class="summary-value summary-blue">
                                    S/ @totalRendido.ToString("N2")
                                </div>
                            </div>
                        </div>
                    </div>

                </div>
            </div>

            @if (rendicion?.IdEstadoRendicion == 1)
            {
                <div class="panel">
                    <div class="panel-header">
                        AGREGAR NUEVO GASTO
                    </div>

                    <div class="panel-body">
                        <form asp-controller="Gasto"
                              asp-action="Create"
                              method="post"
                              enctype="multipart/form-data">

                            <input type="hidden"
                                   name="IdRendicion"
                                   value="@rendicion.IdRendicion" />

                            <div class="row g-3">

                                <div class="col-md-4">
                                    <label class="form-label">Fecha del gasto</label>

                                    <input type="date"
                                           name="Fecha"
                                           class="form-control"
                                           min="@rendicion.FechaInicio.ToString("yyyy-MM-dd")"
                                           max="@rendicion.FechaFin.ToString("yyyy-MM-dd")"
                                           required />

                                    <small class="text-muted">
                                        Solo se permiten fechas entre
                                        @rendicion.FechaInicio.ToString("dd/MM/yyyy")
                                        y
                                        @rendicion.FechaFin.ToString("dd/MM/yyyy").
                                    </small>
                                </div>

                                <div class="col-md-4">
                                    <label class="form-label">Tipo de Gasto</label>
                                    <select name="IdTipoGasto"
                                            class="form-select"
                                            required>
                                        <option value="">Seleccionar tipo</option>

                                        @if (tiposGasto != null)
                                        {
                                            foreach (var item in tiposGasto)
                                            {
                                                <option value="@item.IdTipoGasto">
                                                    @item.Nombre
                                                </option>
                                            }
                                        }
                                    </select>
                                </div>

                                <div class="col-md-4">
                                    <label class="form-label">Tipo Comprobante</label>
                                    <select name="IdTipoComprobante"
                                            class="form-select"
                                            required>
                                        <option value="">Seleccionar comprobante</option>

                                        @if (tiposComprobante != null)
                                        {
                                            foreach (var item in tiposComprobante)
                                            {
                                                <option value="@item.IdTipoComprobante">
                                                    @item.Nombre
                                                </option>
                                            }
                                        }
                                    </select>
                                </div>

                                <div class="col-md-4">
                                    <label class="form-label">Serie</label>
                                    <input name="Serie"
                                           class="form-control"
                                           placeholder="F001" />
                                </div>

                                <div class="col-md-4">
                                    <label class="form-label">Número</label>
                                    <input name="Numero"
                                           class="form-control"
                                           placeholder="000123" />
                                </div>

                                <div class="col-md-4">
                                    <label class="form-label">Detalle</label>
                                    <input name="Detalle"
                                           class="form-control"
                                           placeholder="Ej. Almuerzo" />
                                </div>

                                <div class="col-md-4">
                                    <label class="form-label">
                                        Monto total del comprobante (S/)
                                    </label>

                                    <input type="number"
                                           id="montoTotal"
                                           name="MontoTotal"
                                           class="form-control"
                                           min="0.01"
                                           step="0.01"
                                           placeholder="0.00"
                                           required />

                                    <small class="text-muted">
                                        Ingrese el importe total pagado.
                                    </small>
                                </div>

                                <div class="col-md-4">
                                    <label class="form-label d-block">
                                        Tipo de operación
                                    </label>

                                    <div class="form-check mt-2">
                                        <input type="checkbox"
                                               id="exoneracionIGV"
                                               name="ExoneracionIGV"
                                               value="true"
                                               class="form-check-input" />

                                        <label class="form-check-label"
                                               for="exoneracionIGV">
                                            Exonerado de IGV
                                        </label>
                                    </div>

                                    <small class="text-muted">
                                        Marque esta opción si el comprobante no incluye IGV.
                                    </small>
                                </div>

                                <div class="col-md-4">
                                    <label class="form-label">
                                        Valor de venta (base)
                                    </label>

                                    <div class="input-group">
                                        <span class="input-group-text">S/</span>

                                        <input type="number"
                                               id="valorVenta"
                                               name="ValorVenta"
                                               class="form-control"
                                               step="0.01"
                                               value="0.00"
                                               readonly />
                                    </div>
                                </div>

                                <div class="col-md-4">
                                    <label class="form-label">
                                        IGV (18 %)
                                    </label>

                                    <div class="input-group">
                                        <span class="input-group-text">S/</span>

                                        <input type="number"
                                               id="igvCalculado"
                                               name="IGV"
                                               class="form-control"
                                               step="0.01"
                                               value="0.00"
                                               readonly />
                                    </div>
                                </div>

                                <div class="col-md-8">
                                    <div class="tax-summary">
                                        <div class="row text-center g-3">
                                            <div class="col-md-4">
                                                <small class="text-muted d-block">
                                                    Valor de venta
                                                </small>
                                                <strong id="resumenValorVenta">
                                                    S/ 0.00
                                                </strong>
                                            </div>

                                            <div class="col-md-4">
                                                <small class="text-muted d-block">
                                                    IGV
                                                </small>
                                                <strong id="resumenIgv">
                                                    S/ 0.00
                                                </strong>
                                            </div>

                                            <div class="col-md-4">
                                                <small class="text-muted d-block">
                                                    Total
                                                </small>
                                                <strong id="resumenTotal"
                                                        class="text-primary">
                                                    S/ 0.00
                                                </strong>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <div class="col-md-4">
                                    <label class="form-label">Comprobante Archivo</label>
                                    <input type="file"
                                           name="archivo"
                                           class="form-control" />
                                </div>
                                <div class="col-md-4">
                                    <label class="form-label">RUC</label>

                                    <div class="input-group">
                                        <input type="text"
                                               id="ruc"
                                               name="Ruc"
                                               class="form-control"
                                               maxlength="11"
                                               inputmode="numeric"
                                               pattern="[0-9]{11}"
                                               placeholder="20123456789"
                                               required />

                                        <button type="button"
                                                id="btnConsultarRuc"
                                                class="btn btn-outline-primary">
                                            Buscar
                                        </button>
                                    </div>

                                    <div id="mensajeRuc" class="form-text"></div>
                                </div>

                                <div class="col-md-8">
                                    <label class="form-label">Razón Social</label>

                                    <input type="text"
                                           id="razonSocial"
                                           name="RazonSocial"
                                           class="form-control"
                                           readonly
                                           required />
                                </div>

                                <div class="col-12">

                                    <label for="domicilioFiscal"
                                           class="form-label">

                                        Domicilio fiscal

                                    </label>

                                    <input type="text"
                                           id="domicilioFiscal"
                                           name="DomicilioFiscal"
                                           class="form-control"
                                           maxlength="300"
                                           placeholder="Ingrese o corrija el domicilio fiscal"
                                           required />

                                    <small class="text-muted">

                                        El sistema intentará completar el domicilio al consultar el RUC.
                                        Puede editarlo si está vacío, incompleto o es incorrecto.

                                    </small>
                                </div>

                            </div>

                            <div class="mt-4">
                                <button type="submit"
                                        class="btn btn-dark-custom px-4">
                                    <i class="bi bi-plus-circle me-1"></i>
                                    Agregar gasto
                                </button>
                            </div>

                        </form>
                    </div>
                </div>
            }
            else
            {
                <div class="alert alert-info">
                    Esta rendición ya fue enviada. No se pueden agregar ni eliminar gastos.
                </div>
            }

        </div>

        <div class="col-lg-4">

            <div class="panel mb-4">
                <div class="panel-header">
                    INFORMACIÓN DE LA RENDICIÓN
                </div>

                <div class="panel-body">

                    <div class="table-responsive">

                        <table class="table table-bordered table-info mb-0">
                            <tr>
                                <th>Solicitud</th>
                                <td>@rendicion?.IdSolicitud</td>
                            </tr>
                            <tr>
                                <th>Destino</th>
                                <td>@rendicion?.Solicitud?.Destino</td>
                            </tr>
                            <tr>
                                <th>Motivo</th>
                                <td>@rendicion?.Solicitud?.Motivo</td>
                            </tr>
                            <tr>
                                <th>Fecha Inicio</th>
                                <td>@rendicion?.FechaInicio.ToString("dd/MM/yyyy")</td>
                            </tr>
                            <tr>
                                <th>Fecha Fin</th>
                                <td>@rendicion?.FechaFin.ToString("dd/MM/yyyy")</td>
                            </tr>
                            <tr>
                                <th>Monto Aprobado</th>
                                <td>S/ @montoAprobado.ToString("N2")</td>
                            </tr>
                            <tr>
                                <th>Estado</th>
                                <td>
                                    @if (rendicion?.IdEstadoRendicion == 1)
                                    {
                                        <span class="badge bg-primary">En proceso</span>
                                    }
                                    else if (rendicion?.IdEstadoRendicion == 2)
                                    {
                                        <span class="badge bg-warning text-dark">Pendiente de revisión</span>
                                    }
                                    else if (rendicion?.IdEstadoRendicion == 3)
                                    {
                                        <span class="badge bg-success">Aprobada</span>
                                    }
                                    else if (rendicion?.IdEstadoRendicion == 4)
                                    {
                                        <span class="badge bg-danger">Rechazada</span>
                                    }
                                </td>
                            </tr>
                        </table>

                    </div>

                </div>
            </div>

            <div class="panel mb-4">
                <div class="panel-header">
                    RESUMEN
                </div>

                <div class="panel-body">
                    <div class="summary-card mb-3">
                        <div class="small-label summary-green">
                            Monto Aprobado
                        </div>
                        <div class="summary-value summary-green">
                            S/ @montoAprobado.ToString("N2")
                        </div>
                    </div>

                    <div class="summary-card mb-3">
                        <div class="small-label summary-orange">
                            Total Rendido
                        </div>
                        <div class="summary-value">
                            S/ @totalRendido.ToString("N2")
                        </div>
                    </div>

                    <div class="summary-card">
                        <div class="small-label summary-blue">
                            Saldo Disponible
                        </div>
                        <div class="summary-value summary-blue">
                            S/ @saldoDisponible.ToString("N2")
                        </div>
                    </div>
                </div>
            </div>

            @if (rendicion != null &&
            rendicion.IdEstadoRendicion == 1 &&
            rendicion.Saldo > 0)
            {
                <div class="panel mb-4 @(devolucion == null ? "devolucion-pendiente" : "devolucion-ok")">
                    <div class="panel-header">
                        DEVOLUCIÓN DE SALDO
                    </div>

                    <div class="panel-body">
                        @if (devolucion == null)
                        {
                            <div class="alert alert-warning">
                                Tiene un saldo pendiente de devolución de
                                <strong>S/ @rendicion.Saldo.ToString("N2")</strong>.
                                Debe registrar el depósito antes de enviar la rendición.
                            </div>

                            <form asp-controller="DevolucionSaldo"
                                  asp-action="Registrar"
                                  method="post"
                                  enctype="multipart/form-data">

                                <input type="hidden"
                                       name="IdRendicion"
                                       value="@rendicion.IdRendicion" />

                                <div class="mb-3">
                                    <label class="form-label">Monto a devolver</label>
                                    <input type="number"
                                           name="Monto"
                                           class="form-control"
                                           value="@rendicion.Saldo.ToString("0.00", System.Globalization.CultureInfo.InvariantCulture)"
                                           step="0.01"
                                           readonly />
                                </div>

                                <div class="mb-3">
                                    <label class="form-label">Fecha del depósito</label>
                                    <input type="date"
                                           name="Fecha"
                                           class="form-control"
                                           value="@DateTime.Now.ToString("yyyy-MM-dd")"
                                           required />
                                </div>

                                <div class="mb-3">
                                    <label class="form-label">Banco</label>
                                    <input type="text"
                                           name="Banco"
                                           class="form-control"
                                           maxlength="100"
                                           placeholder="Ej. BCP, BBVA, Interbank"
                                           required />
                                </div>

                                <div class="mb-3">
                                    <label class="form-label">Número de operación</label>
                                    <input type="text"
                                           name="NumeroOperacion"
                                           class="form-control"
                                           maxlength="100"
                                           required />
                                </div>

                                <div class="mb-3">
                                    <label class="form-label">Voucher</label>
                                    <input type="file"
                                           name="voucher"
                                           class="form-control"
                                           accept=".pdf,.jpg,.jpeg,.png"
                                           required />
                                </div>

                                <div class="mb-3">
                                    <label class="form-label">Observaciones</label>
                                    <textarea name="Observaciones"
                                              class="form-control"
                                              rows="3"
                                              maxlength="500"></textarea>
                                </div>

                                <button type="submit"
                                        class="btn btn-primary w-100">
                                    Registrar devolución
                                </button>
                            </form>
                        }
                        else
                        {
                            <div class="alert alert-success">
                                Devolución registrada correctamente.
                            </div>

                            <div class="table-responsive">

                                <table class="table table-bordered table-info">
                                    <tr>
                                        <th>Monto</th>
                                        <td>S/ @devolucion.Monto.ToString("N2")</td>
                                    </tr>
                                    <tr>
                                        <th>Fecha</th>
                                        <td>@devolucion.Fecha.ToString("dd/MM/yyyy")</td>
                                    </tr>
                                    <tr>
                                        <th>Banco</th>
                                        <td>@devolucion.Banco</td>
                                    </tr>
                                    <tr>
                                        <th>N.º operación</th>
                                        <td>@devolucion.NumeroOperacion</td>
                                    </tr>
                                    <tr>
                                        <th>Voucher</th>
                                        <td>
                                            @if (!string.IsNullOrWhiteSpace(devolucion.Voucher))
                                            {
                                                <a href="@devolucion.Voucher"
                                                   target="_blank"
                                                   rel="noopener"
                                                   class="btn btn-outline-primary btn-sm">
                                                    Ver voucher
                                                </a>
                                            }
                                            else
                                            {
                                                <span class="text-muted">Sin archivo</span>
                                            }
                                        </td>
                                    </tr>
                                    <tr>
                                        <th>Observaciones</th>
                                        <td>
                                            @(string.IsNullOrWhiteSpace(devolucion.Observaciones)
                                                ? "-"
                                                : devolucion.Observaciones)
                                        </td>
                                    </tr>
                                </table>

                            </div>

                            <form asp-controller="DevolucionSaldo"
                                  asp-action="Eliminar"
                                  method="post">

                                <input type="hidden"
                                       name="id"
                                       value="@devolucion.IdDevolucionSaldo" />

                                <input type="hidden"
                                       name="idRendicion"
                                       value="@rendicion.IdRendicion" />

                                <button type="submit"
                                        class="btn btn-outline-danger w-100"
                                        onclick="return confirm('¿Desea eliminar la devolución registrada?');">
                                    Eliminar devolución
                                </button>
                            </form>
                        }
                    </div>
                </div>
            }

            <div class="panel">
                <div class="panel-header">
                    ACCIONES
                </div>

                <div class="panel-body d-grid gap-3">

                    @if (rendicion?.IdEstadoRendicion == 1)
                    {
                        var puedeEnviar =
                        rendicion.Total > 0 &&
                        (rendicion.Saldo <= 0 || devolucion != null);

                        <form asp-controller="Gasto"
                              asp-action="EnviarRendicion"
                              method="post">

                            <input type="hidden"
                                   name="idRendicion"
                                   value="@rendicion.IdRendicion" />

                            <button type="submit"
                                    class="btn btn-success w-100"
                                    disabled="@(!puedeEnviar)"
                                    onclick="return confirm('¿Desea enviar esta rendición para revisión?');">
                                <i class="bi bi-send-check-fill me-1"></i>
                                Finalizar y enviar a revisión
                            </button>
                        </form>

                        @if (rendicion.Total <= 0)
                        {
                            <small class="text-danger">
                                Debe registrar al menos un gasto.
                            </small>
                        }
                        else if (rendicion.Saldo > 0 && devolucion == null)
                        {
                            <small class="text-danger">
                                Debe registrar la devolución del saldo pendiente.
                            </small>
                        }
                    }

                    <a asp-controller="Rendicion"
                       asp-action="MisRendiciones"
                       class="btn btn-outline-secondary">
                        Historial de Rendiciones
                    </a>

                    <a asp-controller="Rendicion"
                       asp-action="Index"
                       class="btn btn-outline-secondary">
                        Volver
                    </a>

                </div>
            </div>

        </div>

    </div>

    <div class="mt-4">
        <a asp-controller="Rendicion"
           asp-action="Index"
           class="btn btn-secondary">

            <i class="bi bi-arrow-left"></i>
            Regresar

        </a>
    </div>

</div>

<script>
    document.addEventListener("DOMContentLoaded", function () {
        const rucInput = document.getElementById("ruc");
        const boton = document.getElementById("btnConsultarRuc");
        const razonSocial = document.getElementById("razonSocial");
        const domicilioFiscal = document.getElementById("domicilioFiscal");
        const mensaje = document.getElementById("mensajeRuc");

        if (!rucInput || !boton || !razonSocial || !domicilioFiscal || !mensaje) {
            return;
        }

        async function consultarRuc() {
            const ruc = rucInput.value.trim();

            razonSocial.value = "";
            domicilioFiscal.value = "";
            mensaje.textContent = "";

            if (!/^\d{11}$/.test(ruc)) {
                mensaje.textContent = "Ingrese un RUC válido de 11 dígitos.";
                mensaje.className = "form-text text-danger";
                return;
            }

            boton.disabled = true;
            boton.textContent = "Buscando...";

            try {
                const url =
                    '@Url.Action("ConsultarRuc", "Gasto")' +
                    '?ruc=' +
                    encodeURIComponent(ruc);

                const response = await fetch(url);

                const data = await response.json();

                if (!response.ok) {
                    throw new Error(data.mensaje || "No se encontró el RUC.");
                }

                razonSocial.value = data.razonSocial ?? "";
                domicilioFiscal.value = data.domicilioFiscal ?? "";

                mensaje.textContent =
                    `Estado: ${data.estado ?? "-"} | Condición: ${data.condicion ?? "-"}`;

                mensaje.className = "form-text text-success";
            } catch (error) {
                mensaje.textContent = error.message;
                mensaje.className = "form-text text-danger";
            } finally {
                boton.disabled = false;
                boton.textContent = "Buscar";
            }
        }

        boton.addEventListener("click", consultarRuc);

        rucInput.addEventListener("blur", function () {
            if (/^\d{11}$/.test(rucInput.value.trim())) {
                consultarRuc();
            }
        });

        rucInput.addEventListener("input", function () {
            rucInput.value = rucInput.value.replace(/\D/g, "").slice(0, 11);
        });

        const montoTotalInput =
            document.getElementById("montoTotal");

        const exoneracionInput =
            document.getElementById("exoneracionIGV");

        const valorVentaInput =
            document.getElementById("valorVenta");

        const igvCalculadoInput =
            document.getElementById("igvCalculado");

        const resumenValorVenta =
            document.getElementById("resumenValorVenta");

        const resumenIgv =
            document.getElementById("resumenIgv");

        const resumenTotal =
            document.getElementById("resumenTotal");

        function calcularIgv() {
            if (!montoTotalInput ||
                !exoneracionInput ||
                !valorVentaInput ||
                !igvCalculadoInput) {
                return;
            }

            const montoTotal =
                parseFloat(montoTotalInput.value) || 0;

            let valorVenta = 0;
            let igv = 0;

            if (montoTotal > 0) {
                if (exoneracionInput.checked) {
                    valorVenta = montoTotal;
                    igv = 0;
                }
                else {
                    valorVenta =
                        Math.round((montoTotal / 1.18) * 100) / 100;

                    igv =
                        Math.round((montoTotal - valorVenta) * 100) / 100;
                }
            }

            valorVentaInput.value =
                valorVenta.toFixed(2);

            igvCalculadoInput.value =
                igv.toFixed(2);

            if (resumenValorVenta) {
                resumenValorVenta.textContent =
                    `S/ ${valorVenta.toFixed(2)}`;
            }

            if (resumenIgv) {
                resumenIgv.textContent =
                    `S/ ${igv.toFixed(2)}`;
            }

            if (resumenTotal) {
                resumenTotal.textContent =
                    `S/ ${montoTotal.toFixed(2)}`;
            }
        }

        montoTotalInput?.addEventListener(
            "input",
            calcularIgv);

        exoneracionInput?.addEventListener(
            "change",
            calcularIgv);

        calcularIgv();
    });
</script>