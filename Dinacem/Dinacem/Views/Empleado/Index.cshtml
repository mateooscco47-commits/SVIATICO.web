@{
    ViewData["Title"] = "Panel del Empleado";
    Layout = "~/Views/Shared/_LayoutEmpleado.cshtml";
}

<!DOCTYPE html>
<html lang="es">
<head>

    <meta charset="utf-8" />

    <meta name="viewport" content="width=device-width, initial-scale=1">

    <title>DINACEM - Representante</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

    <style>

        body {
            background: #f4f6f9;
        }

        .card-opcion {
            border: none;
            border-radius: 15px;
            transition: .3s;
        }

            .card-opcion:hover {
                transform: translateY(-5px);
                box-shadow: 0 10px 20px rgba(0,0,0,.15);
            }

        .icono {
            font-size: 55px;
        }

    </style>

</head>

<body>

    <div class="container py-5">

        <div class="text-center mb-5">

            <h2 class="text-primary fw-bold">
                SISTEMA DE VIÁTICOS
            </h2>

            <h4>Panel del Representante</h4>

            <p class="text-muted">
                Bienvenido al sistema de gestión de viáticos
            </p>

        </div>

        <div class="row g-4">

            <!-- Nueva Solicitud -->

            <div class="col-md-4">

                <div class="card card-opcion shadow text-center p-4">

                    <div class="icono">
                        ??
                    </div>

                    <h5 class="mt-3">
                        Nueva Solicitud
                    </h5>

                    <p class="text-muted">

                        Registrar una nueva solicitud de viáticos.

                    </p>

                    <a asp-controller="Solicitud"
                       asp-action="Create"
                       class="btn btn-primary">

                        Registrar

                    </a>

                </div>

            </div>

            <!-- Mis Solicitudes -->

            <div class="col-md-4">

                <div class="card card-opcion shadow text-center p-4">

                    <div class="icono">
                        ??
                    </div>

                    <h5 class="mt-3">

                        Mis Solicitudes

                    </h5>

                    <p class="text-muted">

                        Consultar el estado de mis solicitudes.

                    </p>

                    <a asp-controller="Solicitud"
                       asp-action="MisSolicitudes"
                       class="btn btn-success">

                        Ver Solicitudes

                    </a>

                </div>

            </div>

            <!-- Rendición -->

            <div class="col-md-4">

                <div class="card card-opcion shadow text-center p-4">

                    <div class="icono">
                        ??
                    </div>

                    <h5 class="mt-3">

                        Rendición de Gastos

                    </h5>

                    <p class="text-muted">

                        Registrar los gastos de una solicitud aprobada.

                    </p>

                    <a asp-controller="Rendicion"
                       asp-action="Index"
                       class="btn btn-warning">

                        Rendiciones

                    </a>

                </div>

            </div>

        </div>

        <div class="row mt-5">

            <div class="col-md-12 text-center">

                <a asp-controller="Home"
                   asp-action="Logout"
                   class="btn btn-danger">

                    Cerrar Sesión

                </a>

            </div>

        </div>

    </div>

</body>
</html>