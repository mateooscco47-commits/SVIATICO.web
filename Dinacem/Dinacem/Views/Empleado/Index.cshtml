@{
    ViewData["Title"] = "Panel Empleado";
    Layout = null;
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

<style>
    body {
        background: #f6f8fb;
        font-family: Segoe UI, sans-serif;
    }

    .topbar {
        height: 72px;
        background: #fff;
        border-bottom: 1px solid #e5e7eb;
        display: flex;
        align-items: center;
        padding: 0 45px;
    }

    .brand {
        color: #1e3f8f;
        font-weight: 700;
        margin-right: 35px;
    }

    .page-title {
        font-size: 20px;
        font-weight: 700;
        color: #0f172a;
    }

    .user-text {
        margin-left: auto;
        font-weight: 600;
    }

    .card-option {
        border: 1px solid #dbe1ea;
        border-radius: 14px;
        background: white;
        padding: 28px;
        box-shadow: 0 4px 12px rgba(15, 23, 42, .05);
        transition: .2s;
    }

        .card-option:hover {
            transform: translateY(-4px);
        }

    .icon-box {
        font-size: 42px;
    }
</style>

<div class="topbar">
    <div class="brand">DINACEN</div>
    <div class="page-title">Panel del Empleado</div>
    <div class="user-text">Empleado</div>
    <a href="/Home/Logout" class="btn btn-sm btn-outline-secondary ms-3">Salir</a>
</div>

<div class="container py-5">

    <h4 class="mb-4">Bienvenido al Sistema de Viáticos</h4>

    <div class="row g-4">

        <div class="col-md-4">
            <div class="card-option text-center">
                <div class="icon-box mb-3">??</div>
                <h5>Nueva Solicitud</h5>
                <p class="text-muted">
                    Registra una solicitud de presupuesto para viáticos.
                </p>
                <a href="/Solicitud/Create" class="btn btn-primary w-100">
                    Registrar Solicitud
                </a>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card-option text-center">
                <div class="icon-box mb-3">?</div>
                <h5>Mis Solicitudes</h5>
                <p class="text-muted">
                    Consulta el estado de tus solicitudes enviadas.
                </p>
                <a href="/Solicitud/MisSolicitudes" class="btn btn-primary w-100">
                    Ver Solicitudes
                </a>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card-option text-center">
                <div class="icon-box mb-3">??</div>
                <h5>Mis Rendiciones</h5>
                <p class="text-muted">
                    Registra gastos cuando una solicitud sea aprobada.
                </p>
                <a href="/Rendicion/MisRendiciones" class="btn btn-primary w-100">
                    Ver Rendiciones
                </a>
            </div>
        </div>

    </div>
</div>