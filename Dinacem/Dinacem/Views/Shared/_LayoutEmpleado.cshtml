<!DOCTYPE html>
<html lang="es">
<head>

    <meta charset="utf-8" />

    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <title>@ViewData["Title"] - DINACEM</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
          rel="stylesheet" />

    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css"
          rel="stylesheet" />

    <style>

        body {
            background: #f5f7fb;
        }

        .navbar-top {
            background: white;
            border-bottom: 1px solid #dfe4ea;
        }

        .logo {
            font-size: 24px;
            font-weight: bold;
            color: #0d6efd;
        }

        .menu {
            background: #1e293b;
        }

            .menu .nav-link {
                color: white;
                font-weight: 500;
                padding: 15px 25px;
                transition: .3s;
            }

                .menu .nav-link:hover {
                    background: #2563eb;
                    color: white;
                }

            .menu .active {
                background: #2563eb;
            }

        .contenido {
            padding: 30px;
        }

    </style>

</head>

<body>

    <!-- Barra Superior -->

    <nav class="navbar navbar-expand-lg navbar-top">

        <div class="container-fluid">

            <span class="logo">
                DINACEM
            </span>

            <span class="ms-4 fs-5">
                Sistema de Viáticos
            </span>

            <div class="ms-auto">

                <span class="me-4">
                    <i class="bi bi-person-circle"></i>
                    Representante
                </span>

                <a asp-controller="Home"
                   asp-action="Logout"
                   class="btn btn-outline-danger">

                    <i class="bi bi-box-arrow-right"></i>
                    Salir

                </a>

            </div>

        </div>

    </nav>

    <!-- Menú -->

    <nav class="navbar navbar-expand-lg menu">

        <div class="container-fluid">

            <ul class="navbar-nav">

                <li class="nav-item">

                    <a class="nav-link"
                       asp-controller="Solicitud"
                       asp-action="Create">

                        <i class="bi bi-file-earmark-plus"></i>
                        Nueva Solicitud

                    </a>

                </li>

                <li class="nav-item">

                    <a class="nav-link"
                       asp-controller="Solicitud"
                       asp-action="MisSolicitudes">

                        <i class="bi bi-list-check"></i>
                        Mis Solicitudes

                    </a>

                </li>

                <li class="nav-item">

                    <a class="nav-link"
                       asp-controller="Rendicion"
                       asp-action="Index">

                        <i class="bi bi-cash-stack"></i>
                        Rendiciones

                    </a>

                </li>

                <li class="nav-item">

                    <a class="nav-link"
                       asp-controller="Rendicion"
                       asp-action="MisRendiciones">

                        <i class="bi bi-clock-history"></i>
                        Historial

                    </a>

                </li>

                <li class="nav-item">

                    <a class="nav-link"
                       asp-controller="Empleado"
                       asp-action="Perfil">

                        <i class="bi bi-person"></i>
                        Mi Perfil

                    </a>

                </li>

            </ul>

        </div>

    </nav>

    <!-- Contenido -->

    <div class="contenido">

        @RenderBody()

    </div>

    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

    @await RenderSectionAsync("Scripts", required: false)

</body>

</html>