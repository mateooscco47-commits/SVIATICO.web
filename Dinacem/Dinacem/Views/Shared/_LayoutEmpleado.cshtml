<!DOCTYPE html>
<html lang="es">

<head>

    <meta charset="utf-8" />

    <meta name="viewport"
          content="width=device-width, initial-scale=1.0" />

    <title>
        @ViewData["Title"] - DINACEM
    </title>

    <!-- Bootstrap -->

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
          rel="stylesheet" />

    <!-- Bootstrap Icons -->

    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css"
          rel="stylesheet" />

    <!-- CSS Layout Empleado -->

    <link rel="stylesheet"
          href="~/css/layout-empleado.css"
          asp-append-version="true" />

    <style>

        body {
            min-height: 100vh;
            margin: 0;
            background: #f5f7fb;
        }

        .navbar-dinacen {
            position: sticky;
            top: 0;
            z-index: 1030;
            background: #ffffff;
            border-bottom: 1px solid #e2e8f0;
            box-shadow: 0 2px 10px rgba(15, 23, 42, .07);
        }

        .logo-dinacen {
            width: auto;
            max-width: 155px;
            height: 44px;
            object-fit: contain;
        }

        .navbar-toggler {
            border: 1px solid #cbd5e1;
            box-shadow: none !important;
        }

        .navbar-nav {
            gap: 4px;
        }

            .navbar-nav .nav-link {
                display: flex;
                align-items: center;
                gap: 7px;
                padding: 10px 13px;
                color: #334155;
                border-radius: 9px;
                font-size: 14px;
                font-weight: 700;
                transition: background-color .2s ease, color .2s ease;
            }

                .navbar-nav .nav-link:hover {
                    color: #1d4ed8;
                    background: #eff6ff;
                }

                .navbar-nav .nav-link.active {
                    color: #ffffff;
                    background: #2563eb;
                }

        .usuario-panel {
            display: flex;
            align-items: center;
            gap: 13px;
            margin-left: 15px;
        }

        .usuario-info {
            display: flex;
            align-items: center;
            gap: 8px;
            color: #334155;
            font-size: 14px;
            font-weight: 700;
            white-space: nowrap;
        }

            .usuario-info i {
                color: #2563eb;
                font-size: 24px;
            }

        .btn-salir {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            padding: 8px 15px;
            color: #dc3545;
            background: #ffffff;
            border: 1px solid #dc3545;
            border-radius: 9px;
            font-size: 14px;
            font-weight: 700;
        }

            .btn-salir:hover {
                color: #ffffff;
                background: #dc3545;
            }

        main {
            width: 100%;
            padding: 28px;
        }

        @@media (max-width: 1199.98px) {
            .navbar-nav .nav-link {
                padding-left: 10px;
                padding-right: 10px;
                font-size: 13px;
            }

            .usuario-panel {
                margin-left: 8px;
            }
        }

        @@media (max-width: 991.98px) {
            .navbar-collapse {
                padding-top: 15px;
                padding-bottom: 8px;
            }

            .navbar-nav {
                gap: 7px;
            }

                .navbar-nav .nav-link {
                    width: 100%;
                    padding: 12px 14px;
                }

            .usuario-panel {
                width: 100%;
                margin-top: 16px;
                margin-left: 0;
                padding-top: 15px;
                border-top: 1px solid #e2e8f0;
            }

            .usuario-info {
                flex: 1;
            }

            .btn-salir {
                justify-content: center;
            }

            main {
                padding: 20px;
            }
        }

        @@media (max-width: 575.98px) {
            .logo-dinacen {
                max-width: 125px;
                height: 39px;
            }

            .usuario-panel {
                align-items: stretch;
                flex-direction: column;
            }

            .usuario-info {
                justify-content: center;
                padding: 8px;
                background: #f8fafc;
                border-radius: 9px;
            }

            .btn-salir {
                width: 100%;
            }

            main {
                padding: 14px;
            }
        }

    </style>

</head>

<body>

    <header>

        <nav class="navbar navbar-expand-lg navbar-dinacen">

            <div class="container-fluid">

                <!-- LOGO -->

                <a asp-controller="Empleado"
                   asp-action="Index"
                   class="navbar-brand">

                    <img src="~/images/logo-dinacen.png"
                         class="logo-dinacen"
                         alt="DINACEM" />

                </a>

                <!-- BOTÓN MENÚ PARA CELULAR -->

                <button class="navbar-toggler"
                        type="button"
                        data-bs-toggle="collapse"
                        data-bs-target="#menuEmpleado"
                        aria-controls="menuEmpleado"
                        aria-expanded="false"
                        aria-label="Mostrar navegación">

                    <span class="navbar-toggler-icon"></span>

                </button>

                <div class="collapse navbar-collapse"
                     id="menuEmpleado">

                    <!-- NAVEGACIÓN -->

                    <ul class="navbar-nav me-auto mb-2 mb-lg-0">

                        <li class="nav-item">

                            <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Empleado" &&
                                                  ViewContext.RouteData.Values["action"]?.ToString() == "Index"
                                                  ? "active"
                                                  : "")"
                               asp-controller="Empleado"
                               asp-action="Index">

                                <i class="bi bi-house-door-fill"></i>
                                Inicio

                            </a>

                        </li>

                        <li class="nav-item">

                            <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Solicitud" &&
                                                  ViewContext.RouteData.Values["action"]?.ToString() == "Create"
                                                  ? "active"
                                                  : "")"
                               asp-controller="Solicitud"
                               asp-action="Create">

                                <i class="bi bi-file-earmark-plus-fill"></i>
                                Nueva solicitud

                            </a>

                        </li>

                        <li class="nav-item">

                            <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Solicitud" &&
                                                  ViewContext.RouteData.Values["action"]?.ToString() == "MisSolicitudes"
                                                  ? "active"
                                                  : "")"
                               asp-controller="Solicitud"
                               asp-action="MisSolicitudes">

                                <i class="bi bi-list-check"></i>
                                Mis solicitudes

                            </a>

                        </li>

                        <li class="nav-item">

                            <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Rendicion" &&
                                                  ViewContext.RouteData.Values["action"]?.ToString() == "Index"
                                                  ? "active"
                                                  : "")"
                               asp-controller="Rendicion"
                               asp-action="Index">

                                <i class="bi bi-cash-stack"></i>
                                Rendiciones

                            </a>

                        </li>

                        <li class="nav-item">

                            <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Rendicion" &&
                                                  ViewContext.RouteData.Values["action"]?.ToString() == "MisRendiciones"
                                                  ? "active"
                                                  : "")"
                               asp-controller="Rendicion"
                               asp-action="MisRendiciones">

                                <i class="bi bi-clock-history"></i>
                                Historial

                            </a>

                        </li>

                        <li class="nav-item">

                            <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Empleado" &&
                                                  ViewContext.RouteData.Values["action"]?.ToString() == "Perfil"
                                                  ? "active"
                                                  : "")"
                               asp-controller="Empleado"
                               asp-action="Perfil">

                                <i class="bi bi-person-fill"></i>
                                Mi perfil

                            </a>

                        </li>

                    </ul>

                    <!-- USUARIO -->

                    <div class="usuario-panel">

                        <div class="usuario-info">

                            <i class="bi bi-person-circle"></i>

                            <span>
                                Representante
                            </span>

                        </div>

                        <a asp-controller="Home"
                           asp-action="Logout"
                           class="btn btn-salir">

                            <i class="bi bi-box-arrow-right"></i>
                            Salir

                        </a>

                    </div>

                </div>

            </div>

        </nav>

    </header>

    <main>

        @RenderBody()

    </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js">
    </script>

    @await RenderSectionAsync(
            "Scripts",
            required: false)

</body>

</html>