<!DOCTYPE html>
<html lang="es">

<head>

    <meta charset="utf-8" />

    <meta name="viewport"
          content="width=device-width, initial-scale=1.0" />

    <title>
        @ViewData["Title"] - DINACEM
    </title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
          rel="stylesheet" />

    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css"
          rel="stylesheet" />

    <link rel="stylesheet"
          href="~/css/layout-admin.css"
          asp-append-version="true" />

    <style>

        body {
            background: #f5f7fb;
        }

        .navbar-dinacem {
            background: white;
            box-shadow: 0 2px 10px rgba(0,0,0,.08);
        }

        .logo-dinacem {
            height: 45px;
        }

        .navbar-nav .nav-link {
            font-weight: 600;
            color: #334155;
            margin-right: 6px;
            border-radius: 8px;
            transition: .25s;
            padding: 10px 15px;
        }

            .navbar-nav .nav-link:hover {
                background: #e8f1ff;
                color: #0d6efd;
            }

            .navbar-nav .nav-link.active {
                background: #0d6efd;
                color: white !important;
            }

        .usuario-panel {
            display: flex;
            align-items: center;
            gap: 15px;
        }

        .usuario-info {
            display: flex;
            align-items: center;
            gap: 8px;
            font-weight: 600;
            color: #334155;
        }

            .usuario-info i {
                font-size: 25px;
            }

        .btn-salir {
            border-radius: 10px;
            padding: 8px 18px;
        }

        main {
            padding: 25px;
        }

        @@media(max-width:991px) {

            .usuario-panel {
                margin-top: 15px;
                width: 100%;
                justify-content: space-between;
            }

            main {
                padding: 15px;
            }
        }

    </style>

</head>

<body>

    <nav class="navbar navbar-expand-lg navbar-dinacem">

        <div class="container-fluid">

            <!-- LOGO -->

            <a asp-controller="Principal"
               asp-action="Index"
               class="navbar-brand">

                <img src="~/images/logo-dinacen.png"
                     class="logo-dinacem"
                     alt="DINACEM" />

            </a>

            <!-- BOTON CELULAR -->

            <button class="navbar-toggler"
                    type="button"
                    data-bs-toggle="collapse"
                    data-bs-target="#menuAdmin">

                <span class="navbar-toggler-icon"></span>

            </button>

            <div class="collapse navbar-collapse"
                 id="menuAdmin">

                <!-- MENU -->

                <ul class="navbar-nav me-auto">

                    <li class="nav-item">

                        <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString()=="Principal" ? "active" : "")"
                           asp-controller="Principal"
                           asp-action="Index">

                            <i class="bi bi-speedometer2"></i>

                            Dashboard

                        </a>

                    </li>

                    <li class="nav-item">

                        <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString()=="Usuario" ? "active" : "")"
                           asp-controller="Usuario"
                           asp-action="Index">

                            <i class="bi bi-people-fill"></i>

                            Usuarios

                        </a>

                    </li>

                    <li class="nav-item">

                        <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString()=="Solicitud" ? "active" : "")"
                           asp-controller="Solicitud"
                           asp-action="Index">

                            <i class="bi bi-file-earmark-text-fill"></i>

                            Solicitudes

                        </a>

                    </li>

                    <li class="nav-item">

                        <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString()=="Rendicion" ? "active" : "")"
                           asp-controller="Rendicion"
                           asp-action="IndexAdmin">

                            <i class="bi bi-wallet2"></i>

                            Liquidaciones

                        </a>

                    </li>

                    <li class="nav-item">

                        <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString()=="Reporte" ? "active" : "")"
                           asp-controller="Reporte"
                           asp-action="Index">

                            <i class="bi bi-bar-chart-line-fill"></i>

                            Reportes

                        </a>

                    </li>

                    <!--
                    Cuando hagamos la bitácora solo se descomenta

                    <li class="nav-item">

                        <a class="nav-link"
                           asp-controller="Bitacora"
                           asp-action="Index">

                            <i class="bi bi-clock-history"></i>

                            Bitácora

                        </a>

                    </li>
                    -->

                </ul>

                <!-- USUARIO -->

                <div class="usuario-panel">

                    <div class="usuario-info">

                        <i class="bi bi-person-circle"></i>

                        <span>

                            Administrador

                        </span>

                    </div>

                    <a asp-controller="Home"
                       asp-action="Logout"
                       class="btn btn-outline-danger btn-salir">

                        <i class="bi bi-box-arrow-right"></i>

                        Salir

                    </a>

                </div>

            </div>

        </div>

    </nav>

    <main>

        @RenderBody()

    </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js">
    </script>

</body>

</html>