@model List<Dinacem.Models.Usuario>

    @{
    ViewData["Title"] = "Gestión de Usuarios";
    Layout = null;
    }

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

    <style>
        body {
            background: #f6f8fb;
            font-family: Segoe UI, sans-serif;
        }

        .topbar {
            height: 72px;
            background: #fff;
            border-bottom: 1px solid #e5e7eb;
            display: flex;
            align-items: center;
            padding: 0 45px;
        }

        .brand {
            color: #1e3f8f;
            font-weight: 700;
            margin-right: 35px;
        }

        .page-title {
            font-size: 20px;
            font-weight: 700;
            color: #0f172a;
        }

        .admin-text {
            margin-left: auto;
            font-weight: 600;
        }

        .box {
            background: white;
            border: 1px solid #dbe1ea;
            border-radius: 12px;
            padding: 22px;
            box-shadow: 0 4px 12px rgba(15, 23, 42, .05);
        }

        .box-title {
            font-weight: 700;
            margin-bottom: 18px;
            color: #0f172a;
        }

        label {
            font-size: 13px;
            font-weight: 600;
            color: #334155;
            margin-bottom: 5px;
        }

        .form-control, .form-select {
            height: 42px;
            font-size: 14px;
        }

        .btn-dark-custom {
            background: #0f172a;
            color: white;
            font-weight: 700;
            height: 44px;
        }

        .badge-role {
            background: #eef2ff;
            color: #4f46e5;
            font-size: 12px;
            padding: 4px 8px;
            border-radius: 6px;
        }

        table {
            font-size: 14px;
        }

        thead {
            background: #f8fafc;
            color: #64748b;
            font-size: 12px;
            text-transform: uppercase;
        }

        .btn-sm {
            font-size: 12px;
        }
    </style>

    <div class="topbar">
        <div class="brand">DINACEN</div>
        <div class="page-title">Panel de Administración</div>
        <div class="admin-text">Administrador</div>
        <a href="/Home/Logout" class="btn btn-sm btn-outline-secondary ms-3">Salir</a>
    </div>

    <div class="container-fluid px-4 py-4">

        @if (TempData["mensaje"] != null)
    {
        <div class="alert alert-success">
            @TempData["mensaje"]
        </div>
    }

        @if (TempData["error"] != null)
    {
        <div class="alert alert-danger">
            @TempData["error"]
        </div>
    }

        <div class="row g-4">

            <div class="col-lg-4 col-xl-3">
                <div class="box">
                    <div class="box-title">Crear Nuevo Usuario</div>

                    <form asp-controller="Usuario" asp-action="Create" method="post">

                        <div class="mb-3">
                            <label>Rol</label>
                            <select class="form-select" name="IdRol" required>
                                <option value="">Seleccione...</option>
                                <option value="1">Administrador</option>
                                <option value="2">Empleado</option>
                            </select>
                        </div>

                        <div class="mb-3">
                            <label>Nombres</label>
                            <input type="text" class="form-control" name="Nombres" required />
                        </div>

                        <div class="mb-3">
                            <label>Apellidos</label>
                            <input type="text" class="form-control" name="Apellidos" required />
                        </div>

                        <div class="mb-3">
                            <label>Correo</label>
                            <input type="email" class="form-control" name="Correo" placeholder="jperez@dinacen.com" required />
                        </div>

                        <div class="mb-3">
                            <label>Número de Celular</label>
                            <input type="text" class="form-control" name="Celular" />
                        </div>

                        <div class="mb-3">
                            <label>Vehículo</label>
                            <input type="text" class="form-control" name="Vehiculo" />
                        </div>

                        <div class="mb-3">
                            <label>Contraseńa Inicial</label>
                            <input type="password" class="form-control" name="Contrasenia" required />
                        </div>

                        <button type="submit" class="btn btn-dark-custom w-100">
                            Registrar Usuario
                        </button>

                    </form>
                </div>
            </div>

            <div class="col-lg-8 col-xl-9">
                <div class="box">
                    <div class="box-title">Lista de Usuarios</div>

                    <div class="table-responsive">
                        <table class="table align-middle">
                            <thead>
                                <tr>
                                    <th>Usuario</th>
                                    <th>Datos Personales</th>
                                    <th>Contacto</th>
                                    <th>Vehículo</th>
                                    <th class="text-end">Acciones</th>
                                </tr>
                            </thead>

                            <tbody>
                                @if (Model != null && Model.Any())
                            {
                                foreach (var item in Model)
                                {
                                <tr>
                                    <td>
                                        @item.IdUsuario
                                        <br />
                                        <span class="badge-role">
                                            @(item.Rol?.Nombre ?? "Sin rol")
                                        </span>
                                    </td>

                                    <td>
                                        <strong>@item.Nombres @item.Apellidos</strong>
                                    </td>

                                    <td>
                                        @item.Correo
                                        <br />
                                        <span class="text-muted">@item.Celular</span>
                                    </td>

                                    <td>
                                        @(string.IsNullOrWhiteSpace(item.Vehiculo) ? "-" : item.Vehiculo)
                                    </td>

                                    <td class="text-end">
                                        <button class="btn btn-sm btn-warning"
                                                data-bs-toggle="modal"
                                                data-bs-target="#editarUsuario@item.IdUsuario">
                                            Editar
                                        </button>

                                        <form asp-controller="Usuario"
                                              asp-action="Delete"
                                              asp-route-id="@item.IdUsuario"
                                              method="post"
                                              class="d-inline">
                                            <button type="submit"
                                                    class="btn btn-sm btn-danger"
                                                    onclick="return confirm('żDeseas eliminar este usuario?');">
                                                Eliminar
                                            </button>
                                        </form>
                                    </td>
                                </tr>

                                <div class="modal fade" id="editarUsuario@item.IdUsuario" tabindex="-1">
                                    <div class="modal-dialog">
                                        <div class="modal-content">

                                            <form asp-controller="Usuario" asp-action="Edit" method="post">

                                                <div class="modal-header">
                                                    <h5 class="modal-title">Editar Usuario</h5>
                                                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                                                </div>

                                                <div class="modal-body">

                                                    <input type="hidden" name="IdUsuario" value="@item.IdUsuario" />

                                                    <div class="mb-3">
                                                        <label>Rol</label>
                                                        <select class="form-select" name="IdRol">
                                                            <option value="1" selected="@(item.IdRol == 1)">Administrador</option>
                                                            <option value="2" selected="@(item.IdRol == 2)">Empleado</option>
                                                        </select>
                                                    </div>

                                                    <div class="mb-3">
                                                        <label>Nombres</label>
                                                        <input type="text" class="form-control" name="Nombres" value="@item.Nombres" />
                                                    </div>

                                                    <div class="mb-3">
                                                        <label>Apellidos</label>
                                                        <input type="text" class="form-control" name="Apellidos" value="@item.Apellidos" />
                                                    </div>

                                                    <div class="mb-3">
                                                        <label>Correo</label>
                                                        <input type="email" class="form-control" name="Correo" value="@item.Correo" />
                                                    </div>

                                                    <div class="mb-3">
                                                        <label>Celular</label>
                                                        <input type="text" class="form-control" name="Celular" value="@item.Celular" />
                                                    </div>

                                                    <div class="mb-3">
                                                        <label>Vehículo</label>
                                                        <input type="text" class="form-control" name="Vehiculo" value="@item.Vehiculo" />
                                                    </div>

                                                    <div class="mb-3">
                                                        <label>Contraseńa</label>
                                                        <input type="text" class="form-control" name="Contrasenia" value="@item.Contrasenia" />
                                                    </div>

                                                </div>

                                                <div class="modal-footer">
                                                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                                                    <button type="submit" class="btn btn-primary">Guardar Cambios</button>
                                                </div>

                                            </form>

                                        </div>
                                    </div>
                                </div>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="5" class="text-center text-muted">
                                        No hay usuarios registrados.
                                    </td>
                                </tr>
                            }
                            </tbody>

                        </table>
                    </div>

                </div>
            </div>

        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
