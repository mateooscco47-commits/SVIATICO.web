@model List<Dinacem.Models.Usuario>

@{
    ViewData["Title"] = "Gestión de Usuarios";
    Layout = "~/Views/Shared/_LayoutAdministrador.cshtml";

    var totalUsuarios = Model?.Count ?? 0;
    var usuariosActivos = Model?.Count(x => x.Estado) ?? 0;
    var usuariosInactivos = Model?.Count(x => !x.Estado) ?? 0;
}

<style>
    .page-wrapper {
        width: 100%;
        max-width: 1600px;
        margin: 0 auto;
    }

    .page-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 16px;
        margin-bottom: 24px;
        padding: 22px;
        background: #fff;
        border: 1px solid #e2e8f0;
        border-radius: 16px;
        box-shadow: 0 5px 18px rgba(15, 23, 42, .05);
    }

    .page-title {
        margin: 0 0 5px;
        color: #0f172a;
        font-size: 28px;
        font-weight: 800;
    }

    .page-description {
        margin: 0;
        color: #64748b;
        font-size: 14px;
    }

    .summary-card {
        height: 100%;
        padding: 17px 18px;
        background: #fff;
        border: 1px solid #e2e8f0;
        border-radius: 13px;
        box-shadow: 0 4px 12px rgba(15, 23, 42, .04);
    }

    .summary-label {
        color: #64748b;
        font-size: 12px;
        font-weight: 700;
        text-transform: uppercase;
    }

    .summary-value {
        margin-top: 4px;
        color: #0f172a;
        font-size: 26px;
        font-weight: 800;
    }

    .box {
        height: 100%;
        padding: 22px;
        background: #fff;
        border: 1px solid #dbe1ea;
        border-radius: 15px;
        box-shadow: 0 5px 18px rgba(15, 23, 42, .05);
    }

    .box-title {
        display: flex;
        align-items: center;
        gap: 9px;
        margin-bottom: 18px;
        color: #0f172a;
        font-size: 18px;
        font-weight: 800;
    }

    .form-label {
        margin-bottom: 5px;
        color: #334155;
        font-size: 13px;
        font-weight: 600;
    }

    .form-control,
    .form-select {
        min-height: 42px;
        font-size: 14px;
    }

    .btn-dark-custom {
        min-height: 44px;
        color: #fff;
        background: #0f172a;
        font-weight: 700;
    }

        .btn-dark-custom:hover {
            color: #fff;
            background: #111827;
        }

    .badge-role {
        display: inline-block;
        margin-top: 4px;
        padding: 5px 9px;
        color: #4f46e5;
        background: #eef2ff;
        border-radius: 7px;
        font-size: 12px;
        font-weight: 700;
    }

    .badge-status {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        padding: 6px 10px;
        border-radius: 20px;
        font-size: 12px;
        font-weight: 700;
        white-space: nowrap;
    }

    .status-active {
        color: #166534;
        background: #dcfce7;
        border: 1px solid #86efac;
    }

    .status-inactive {
        color: #991b1b;
        background: #fee2e2;
        border: 1px solid #fca5a5;
    }

    .table {
        min-width: 920px;
        font-size: 14px;
    }

        .table thead th {
            color: #64748b;
            background: #f8fafc;
            font-size: 12px;
            text-transform: uppercase;
            white-space: nowrap;
        }

        .table td {
            vertical-align: middle;
        }

    .actions {
        display: flex;
        justify-content: flex-end;
        flex-wrap: wrap;
        gap: 6px;
    }

    .modal-content {
        border: 0;
        border-radius: 15px;
        overflow: hidden;
    }

    .modal-header {
        background: #f8fafc;
        border-bottom: 1px solid #e2e8f0;
    }

    @@media (max-width: 991.98px) {
        .page-header {
            align-items: flex-start;
            flex-direction: column;
        }

            .page-header .btn {
                width: 100%;
            }

        .box {
            padding: 19px;
        }
    }

    @@media (max-width: 767.98px) {
        .page-header {
            padding: 18px;
            border-radius: 13px;
        }

        .page-title {
            font-size: 23px;
        }

        .summary-value {
            font-size: 23px;
        }

        .box {
            padding: 16px;
            border-radius: 13px;
        }

        .box-title {
            font-size: 17px;
        }

        .modal-dialog {
            margin: 12px;
        }

        .modal-footer {
            display: grid;
            grid-template-columns: 1fr;
        }

            .modal-footer .btn {
                width: 100%;
            }
    }
</style>

<div class="page-wrapper">

    <!-- La barra de navegación del administrador ya se carga desde _LayoutAdministrador.cshtml -->

    <div class="page-header">
        <div>
            <h1 class="page-title">
                <i class="bi bi-people-fill me-2"></i>
                Gestión de Usuarios
            </h1>

            <p class="page-description">
                Registre, edite, active o desactive usuarios del sistema.
            </p>
        </div>

        <a asp-controller="Principal"
           asp-action="Index"
           class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left"></i>
            Volver al panel
        </a>
    </div>

    @if (TempData["mensaje"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">
            @TempData["mensaje"]

            <button type="button"
                    class="btn-close"
                    data-bs-dismiss="alert"
                    aria-label="Cerrar">
            </button>
        </div>
    }

    @if (TempData["error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show">
            @Html.Raw(TempData["error"])

            <button type="button"
                    class="btn-close"
                    data-bs-dismiss="alert"
                    aria-label="Cerrar">
            </button>
        </div>
    }

    <div class="row g-3 mb-4">
        <div class="col-12 col-sm-4">
            <div class="summary-card">
                <div class="summary-label">Total de usuarios</div>
                <div class="summary-value">@totalUsuarios</div>
            </div>
        </div>

        <div class="col-12 col-sm-4">
            <div class="summary-card">
                <div class="summary-label text-success">Activos</div>
                <div class="summary-value">@usuariosActivos</div>
            </div>
        </div>

        <div class="col-12 col-sm-4">
            <div class="summary-card">
                <div class="summary-label text-danger">Inactivos</div>
                <div class="summary-value">@usuariosInactivos</div>
            </div>
        </div>
    </div>

    <div class="row g-4">

        <!-- CREAR USUARIO -->
        <div class="col-12 col-xl-3">
            <div class="box">

                <div class="box-title">
                    <i class="bi bi-person-plus-fill text-primary"></i>
                    Crear nuevo usuario
                </div>

                <form asp-controller="Usuario"
                      asp-action="Create"
                      method="post">

                    <div class="mb-3">
                        <label class="form-label">Usuario de acceso</label>
                        <input type="text"
                               class="form-control"
                               name="UsuarioAcceso"
                               maxlength="100"
                               placeholder="Ej. admin001 / P001"
                               required />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Rol</label>
                        <select class="form-select"
                                name="IdRol"
                                required>
                            <option value="">Seleccione...</option>
                            <option value="1">Administrador</option>
                            <option value="2">Empleado</option>
                        </select>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Nombres</label>
                        <input type="text"
                               class="form-control"
                               name="Nombres"
                               maxlength="100"
                               required />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Apellidos</label>
                        <input type="text"
                               class="form-control"
                               name="Apellidos"
                               maxlength="100"
                               required />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Correo</label>
                        <input type="email"
                               class="form-control"
                               name="Correo"
                               maxlength="150"
                               placeholder="jperez@dinacem.com"
                               required />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Número de celular</label>
                        <input type="tel"
                               class="form-control"
                               name="Celular"
                               maxlength="20"
                               inputmode="numeric"
                               placeholder="999999999" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Vehículo</label>
                        <input type="text"
                               class="form-control"
                               name="Vehiculo"
                               maxlength="100"
                               placeholder="Opcional" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Contraseńa inicial</label>
                        <input type="password"
                               class="form-control"
                               name="Contrasenia"
                               autocomplete="new-password"
                               required />
                    </div>

                    <button type="submit"
                            class="btn btn-dark-custom w-100">
                        <i class="bi bi-person-check-fill"></i>
                        Registrar usuario
                    </button>

                </form>
            </div>
        </div>

        <!-- LISTA DE USUARIOS -->
        <div class="col-12 col-xl-9">
            <div class="box">

                <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-2 mb-3">
                    <div class="box-title mb-0">
                        <i class="bi bi-list-ul text-primary"></i>
                        Lista de usuarios
                    </div>

                    <span class="text-muted small">
                        En celular, deslice la tabla horizontalmente.
                    </span>
                </div>

                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">

                        <thead>
                            <tr>
                                <th>Usuario</th>
                                <th>Datos personales</th>
                                <th>Contacto</th>
                                <th>Vehículo</th>
                                <th>Estado</th>
                                <th class="text-end">Acciones</th>
                            </tr>
                        </thead>

                        <tbody>
                            @if (Model != null && Model.Any())
                            {
                                foreach (var item in Model)
                                {
                                    <tr>
                                        <td>
                                            <strong>@item.UsuarioAcceso</strong>
                                            <br />
                                            <span class="badge-role">
                                                @(item.Rol?.Nombre ?? "Sin rol")
                                            </span>
                                        </td>

                                        <td>
                                            <strong>
                                                @item.Nombres @item.Apellidos
                                            </strong>
                                        </td>

                                        <td>
                                            @(string.IsNullOrWhiteSpace(item.Correo)
                                                ? "-"
                                                : item.Correo)

                                            <br />

                                            <small class="text-muted">
                                                @(string.IsNullOrWhiteSpace(item.Celular)
                                                    ? "Sin celular"
                                                    : item.Celular)
                                            </small>
                                        </td>

                                        <td>
                                            @(string.IsNullOrWhiteSpace(item.Vehiculo)
                                                ? "-"
                                                : item.Vehiculo)
                                        </td>

                                        <td>
                                            @if (item.Estado)
                                            {
                                                <span class="badge-status status-active">
                                                    <i class="bi bi-check-circle-fill"></i>
                                                    Activo
                                                </span>
                                            }
                                            else
                                            {
                                                <span class="badge-status status-inactive">
                                                    <i class="bi bi-x-circle-fill"></i>
                                                    Inactivo
                                                </span>
                                            }
                                        </td>

                                        <td>
                                            <div class="actions">

                                                <!-- Cada botón abre el modal del IdUsuario correspondiente -->
                                                <button type="button"
                                                        class="btn btn-sm btn-warning"
                                                        data-bs-toggle="modal"
                                                        data-bs-target="#editarUsuario-@item.IdUsuario">
                                                    <i class="bi bi-pencil-square"></i>
                                                    Editar
                                                </button>

                                                @if (item.Estado)
                                                {
                                                    <form asp-controller="Usuario"
                                                          asp-action="Desactivar"
                                                          asp-route-id="@item.IdUsuario"
                                                          method="post"
                                                          class="d-inline">

                                                        <button type="submit"
                                                                class="btn btn-sm btn-outline-danger"
                                                                onclick="return confirm('żDesea desactivar este usuario?');">
                                                            <i class="bi bi-person-x-fill"></i>
                                                            Desactivar
                                                        </button>
                                                    </form>
                                                }
                                                else
                                                {
                                                    <form asp-controller="Usuario"
                                                          asp-action="Activar"
                                                          asp-route-id="@item.IdUsuario"
                                                          method="post"
                                                          class="d-inline">

                                                        <button type="submit"
                                                                class="btn btn-sm btn-outline-success"
                                                                onclick="return confirm('żDesea activar este usuario?');">
                                                            <i class="bi bi-person-check-fill"></i>
                                                            Activar
                                                        </button>
                                                    </form>
                                                }

                                            </div>
                                        </td>
                                    </tr>

                                    <!-- MODAL EXCLUSIVO DEL USUARIO ACTUAL -->
                                    <div class="modal fade"
                                         id="editarUsuario-@item.IdUsuario"
                                         tabindex="-1"
                                         aria-labelledby="tituloEditarUsuario-@item.IdUsuario"
                                         aria-hidden="true">

                                        <div class="modal-dialog modal-dialog-centered modal-lg">
                                            <div class="modal-content">

                                                <form asp-controller="Usuario"
                                                      asp-action="Edit"
                                                      method="post">

                                                    <div class="modal-header">
                                                        <h5 class="modal-title"
                                                            id="tituloEditarUsuario-@item.IdUsuario">
                                                            <i class="bi bi-pencil-square me-1"></i>
                                                            Editar usuario:
                                                            @item.Nombres @item.Apellidos
                                                        </h5>

                                                        <button type="button"
                                                                class="btn-close"
                                                                data-bs-dismiss="modal"
                                                                aria-label="Cerrar">
                                                        </button>
                                                    </div>

                                                    <div class="modal-body">

                                                        <!-- Este Id garantiza que se edite el usuario seleccionado -->
                                                        <input type="hidden"
                                                               name="IdUsuario"
                                                               value="@item.IdUsuario" />

                                                        <div class="row g-3">

                                                            <div class="col-12 col-md-6">
                                                                <label class="form-label">Usuario de acceso</label>
                                                                <input type="text"
                                                                       class="form-control"
                                                                       name="UsuarioAcceso"
                                                                       value="@item.UsuarioAcceso"
                                                                       maxlength="100"
                                                                       required />
                                                            </div>

                                                            <div class="col-12 col-md-6">
                                                                <label class="form-label">Rol</label>
                                                                <select class="form-select"
                                                                        name="IdRol"
                                                                        required>
                                                                    @if (item.IdRol == 1)
                                                                    {
                                                                        <option value="1" selected>Administrador</option>
                                                                        <option value="2">Empleado</option>
                                                                    }
                                                                    else
                                                                    {
                                                                        <option value="1">Administrador</option>
                                                                        <option value="2" selected>Empleado</option>
                                                                    }
                                                                </select>
                                                            </div>

                                                            <div class="col-12 col-md-6">
                                                                <label class="form-label">Nombres</label>
                                                                <input type="text"
                                                                       class="form-control"
                                                                       name="Nombres"
                                                                       value="@item.Nombres"
                                                                       maxlength="100"
                                                                       required />
                                                            </div>

                                                            <div class="col-12 col-md-6">
                                                                <label class="form-label">Apellidos</label>
                                                                <input type="text"
                                                                       class="form-control"
                                                                       name="Apellidos"
                                                                       value="@item.Apellidos"
                                                                       maxlength="100"
                                                                       required />
                                                            </div>

                                                            <div class="col-12 col-md-6">
                                                                <label class="form-label">Correo</label>
                                                                <input type="email"
                                                                       class="form-control"
                                                                       name="Correo"
                                                                       value="@item.Correo"
                                                                       maxlength="150"
                                                                       required />
                                                            </div>

                                                            <div class="col-12 col-md-6">
                                                                <label class="form-label">Celular</label>
                                                                <input type="tel"
                                                                       class="form-control"
                                                                       name="Celular"
                                                                       value="@item.Celular"
                                                                       maxlength="20"
                                                                       inputmode="numeric" />
                                                            </div>

                                                            <div class="col-12 col-md-6">
                                                                <label class="form-label">Vehículo</label>
                                                                <input type="text"
                                                                       class="form-control"
                                                                       name="Vehiculo"
                                                                       value="@item.Vehiculo"
                                                                       maxlength="100" />
                                                            </div>

                                                            <div class="col-12 col-md-6">
                                                                <label class="form-label">Contraseńa</label>
                                                                <input type="password"
                                                                       class="form-control"
                                                                       name="Contrasenia"
                                                                       value="@item.Contrasenia"
                                                                       autocomplete="new-password"
                                                                       required />
                                                            </div>

                                                        </div>
                                                    </div>

                                                    <div class="modal-footer">
                                                        <button type="button"
                                                                class="btn btn-secondary"
                                                                data-bs-dismiss="modal">
                                                            Cancelar
                                                        </button>

                                                        <button type="submit"
                                                                class="btn btn-primary">
                                                            <i class="bi bi-save-fill"></i>
                                                            Guardar cambios
                                                        </button>
                                                    </div>

                                                </form>
                                            </div>
                                        </div>
                                    </div>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="6"
                                        class="text-center text-muted py-5">
                                        <i class="bi bi-people fs-2 d-block mb-2"></i>
                                        No hay usuarios registrados.
                                    </td>
                                </tr>
                            }
                        </tbody>

                    </table>
                </div>
            </div>
        </div>

    </div>

</div>
