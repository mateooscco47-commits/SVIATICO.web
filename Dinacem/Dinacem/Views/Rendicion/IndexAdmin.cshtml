@model List<Dinacem.Models.Rendicion>

@{
    ViewData["Title"] = "Revisión de Rendiciones";
    Layout = "~/Views/Shared/_LayoutAdministrador.cshtml";
}

<style>
    .card {
        border-radius: 15px;
    }

    .badge-pendiente {
        background: #ffc107;
        color: black;
        padding: 8px 15px;
        border-radius: 20px;
    }
</style>

<div class="container mt-4">

    <div class="card shadow">

        <div class="card-header bg-primary text-white">
            <h3>Rendiciones Pendientes</h3>
        </div>

        <div class="card-body">

            @if (TempData["mensaje"] != null)
            {
                <div class="alert alert-success">
                    @TempData["mensaje"]
                </div>
            }

            @if (TempData["error"] != null)
            {
                <div class="alert alert-danger">
                    @TempData["error"]
                </div>
            }

            <table class="table table-hover table-bordered align-middle">
                <thead class="table-dark">
                    <tr>
                        <th>#</th>
                        <th>Empleado</th>
                        <th>Solicitud</th>
                        <th>Fecha</th>
                        <th>Total</th>
                        <th>Saldo</th>
                        <th>Estado</th>
                        <th width="260">Acciones</th>
                    </tr>
                </thead>

                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            <tr>
                                <td>@item.IdRendicion</td>
                                <td>@item.Usuario?.Nombres @item.Usuario?.Apellidos</td>
                                <td>@item.IdSolicitud</td>
                                <td>@item.Fecha.ToString("dd/MM/yyyy")</td>
                                <td>S/. @item.Total.ToString("N2")</td>
                                <td>S/. @item.Saldo.ToString("N2")</td>
                                <td>
                                    <span class="badge-pendiente">
                                        @item.EstadoRendicion?.Nombre
                                    </span>
                                </td>
                                <td>
                                    <a asp-controller="Rendicion"
                                       asp-action="DetalleAdmin"
                                       asp-route-id="@item.IdRendicion"
                                       class="btn btn-info btn-sm">
                                        Revisar
                                    </a>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="8" class="text-center text-muted">
                                No hay rendiciones pendientes de revisión.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>

        </div>
    </div>
</div>