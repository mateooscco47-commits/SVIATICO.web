@model List<Dinacem.Models.Rendicion>

@{
    ViewData["Title"] = "Liquidaciones";
    Layout = "~/Views/Shared/_LayoutAdministrador.cshtml";

    var totalLiquidaciones = Model?.Count ?? 0;
    var enProceso = Model?.Count(x => x.IdEstadoRendicion == 1) ?? 0;
    var pendientes = Model?.Count(x => x.IdEstadoRendicion == 2) ?? 0;
    var aprobadas = Model?.Count(x => x.IdEstadoRendicion == 3) ?? 0;
    var rechazadas = Model?.Count(x => x.IdEstadoRendicion == 4) ?? 0;

    var reembolsos =
        ViewBag.Reembolsos as List<Dinacem.Models.Reembolso>
        ?? new List<Dinacem.Models.Reembolso>();

    var reembolsosPendientes =
        reembolsos.Count(x => x.IdEstadoReembolso == 2);

    var reembolsosPagados =
        reembolsos.Count(x => x.IdEstadoReembolso == 3);
}

<style>
    .page-wrapper {
        width: 100%;
        max-width: 1650px;
        margin: 0 auto;
    }

    .page-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 16px;
        padding: 22px;
        margin-bottom: 22px;
        background: #fff;
        border: 1px solid #e2e8f0;
        border-radius: 16px;
        box-shadow: 0 5px 18px rgba(15, 23, 42, .05);
    }

    .page-title {
        margin: 0 0 5px;
        color: #0f172a;
        font-size: 28px;
        font-weight: 800;
    }

    .page-description {
        margin: 0;
        color: #64748b;
        font-size: 14px;
    }

    .summary-card {
        height: 100%;
        padding: 18px;
        background: #fff;
        border: 1px solid #e2e8f0;
        border-radius: 13px;
        box-shadow: 0 4px 12px rgba(15, 23, 42, .04);
    }

    .summary-label {
        color: #64748b;
        font-size: 12px;
        font-weight: 700;
        text-transform: uppercase;
    }

    .summary-number {
        margin-top: 4px;
        color: #0f172a;
        font-size: 28px;
        font-weight: 800;
    }

    .panel-card {
        overflow: hidden;
        border: 0;
        border-radius: 15px;
        box-shadow: 0 5px 18px rgba(15, 23, 42, .06);
    }

    .panel-header {
        padding: 18px 20px;
        background: #fff;
        border-bottom: 1px solid #e2e8f0;
    }

    .search-box {
        position: relative;
        width: 100%;
        max-width: 430px;
    }

        .search-box .bi-search {
            position: absolute;
            top: 50%;
            left: 14px;
            z-index: 2;
            color: #94a3b8;
            transform: translateY(-50%);
        }

        .search-box input {
            min-height: 42px;
            padding-left: 40px;
            border-radius: 10px;
        }

    .filters {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
    }

    .filtro-btn.active {
        color: #fff;
        background: #0d6efd;
        border-color: #0d6efd;
    }

    .table {
        min-width: 1180px;
        font-size: 14px;
    }

        .table th {
            color: #64748b;
            font-size: 12px;
            text-transform: uppercase;
            white-space: nowrap;
        }

        .table td {
            vertical-align: middle;
        }

    .estado {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 7px 11px;
        border-radius: 20px;
        font-size: 12px;
        font-weight: 700;
        white-space: nowrap;
    }

    .estado-proceso {
        color: #1d4ed8;
        background: #dbeafe;
        border: 1px solid #93c5fd;
    }

    .estado-pendiente {
        color: #92400e;
        background: #fef3c7;
        border: 1px solid #fcd34d;
    }

    .estado-aprobada {
        color: #166534;
        background: #dcfce7;
        border: 1px solid #86efac;
    }

    .estado-rechazada {
        color: #991b1b;
        background: #fee2e2;
        border: 1px solid #fca5a5;
    }

    .estado-reembolso {
        color: #6b21a8;
        background: #f3e8ff;
        border: 1px solid #d8b4fe;
    }

    .estado-pagado {
        color: #065f46;
        background: #d1fae5;
        border: 1px solid #6ee7b7;
    }

    .accion-proceso {
        color: #64748b;
        font-size: 13px;
    }

    .acciones {
        display: flex;
        justify-content: flex-end;
        flex-wrap: wrap;
        gap: 6px;
    }

    .result-count {
        color: #64748b;
        font-size: 13px;
    }

    @@media (max-width: 991.98px) {
        .page-header {
            align-items: flex-start;
            flex-direction: column;
        }

            .page-header .btn {
                width: 100%;
            }

        .panel-header > div {
            width: 100%;
        }

        .search-box {
            max-width: none;
        }
    }

    @@media (max-width: 767.98px) {
        .page-header {
            padding: 18px;
            border-radius: 13px;
        }

        .page-title {
            font-size: 23px;
        }

        .summary-number {
            font-size: 24px;
        }

        .panel-header {
            padding: 15px;
        }

        .filters .btn {
            flex: 1 1 calc(50% - 8px);
        }
    }

    @@media (max-width: 575.98px) {
        .filters .btn {
            flex: 1 1 100%;
        }

        .summary-card {
            padding: 16px;
        }
    }
</style>

<div class="page-wrapper">

    <!-- La barra de navegación del administrador se carga desde _LayoutAdministrador.cshtml -->

    <div class="page-header">
        <div>
            <h1 class="page-title">
                <i class="bi bi-receipt-cutoff me-2"></i>
                Liquidaciones
            </h1>

            <p class="page-description">
                Consulte todas las rendiciones, filtre por estado y busque por empleado, correo, destino o número.
            </p>
        </div>

        <a asp-controller="Principal"
           asp-action="Index"
           class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left"></i>
            Volver al panel
        </a>
    </div>

    @if (TempData["mensaje"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">
            @TempData["mensaje"]

            <button type="button"
                    class="btn-close"
                    data-bs-dismiss="alert"
                    aria-label="Cerrar">
            </button>
        </div>
    }

    @if (TempData["error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show">
            @Html.Raw(TempData["error"])

            <button type="button"
                    class="btn-close"
                    data-bs-dismiss="alert"
                    aria-label="Cerrar">
            </button>
        </div>
    }

    <!-- RESUMEN -->
    <div class="row g-3 mb-4">

        <div class="col-12 col-sm-6 col-xl">
            <div class="summary-card">
                <div class="summary-label">Total</div>
                <div class="summary-number">@totalLiquidaciones</div>
            </div>
        </div>

        <div class="col-12 col-sm-6 col-xl">
            <div class="summary-card">
                <div class="summary-label text-primary">En proceso</div>
                <div class="summary-number">@enProceso</div>
            </div>
        </div>

        <div class="col-12 col-sm-6 col-xl">
            <div class="summary-card">
                <div class="summary-label text-warning">Pendientes</div>
                <div class="summary-number">@pendientes</div>
            </div>
        </div>

        <div class="col-12 col-sm-6 col-xl">
            <div class="summary-card">
                <div class="summary-label text-success">Aprobadas</div>
                <div class="summary-number">@aprobadas</div>
            </div>
        </div>

        <div class="col-12 col-sm-6 col-xl">
            <div class="summary-card">
                <div class="summary-label text-danger">Rechazadas</div>
                <div class="summary-number">@rechazadas</div>
            </div>
        </div>

        <div class="col-12 col-sm-6 col-xl">
            <div class="summary-card">
                <div class="summary-label" style="color:#7c3aed;">
                    Reembolsos pendientes
                </div>
                <div class="summary-number">
                    @reembolsosPendientes
                </div>
            </div>
        </div>

    </div>

    <div class="card panel-card">

        <div class="panel-header">

            <div class="d-flex flex-column gap-3">

                <div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-center gap-3">

                    <div>
                        <h5 class="mb-1">Listado de liquidaciones</h5>

                        <span class="text-muted">
                            Use la búsqueda y los filtros para encontrar una liquidación.
                        </span>
                    </div>

                    <div class="search-box">
                        <i class="bi bi-search"></i>

                        <input type="search"
                               id="buscarLiquidacion"
                               class="form-control"
                               placeholder="Buscar por empleado, correo, destino o número..."
                               autocomplete="off" />
                    </div>

                </div>

                <div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-center gap-3">

                    <div class="filters">

                        <button type="button"
                                class="btn btn-outline-secondary btn-sm filtro-btn active"
                                data-estado="todos">
                            Todos
                        </button>

                        <button type="button"
                                class="btn btn-outline-primary btn-sm filtro-btn"
                                data-estado="1">
                            En proceso
                        </button>

                        <button type="button"
                                class="btn btn-outline-warning btn-sm filtro-btn"
                                data-estado="2">
                            Pendientes
                        </button>

                        <button type="button"
                                class="btn btn-outline-success btn-sm filtro-btn"
                                data-estado="3">
                            Aprobadas
                        </button>

                        <button type="button"
                                class="btn btn-outline-danger btn-sm filtro-btn"
                                data-estado="4">
                            Rechazadas
                        </button>

                        <button type="button"
                                class="btn btn-outline-secondary btn-sm filtro-btn"
                                data-estado="reembolso">
                            Reembolso pendiente
                        </button>

                    </div>

                    <div class="result-count">
                        Mostrando
                        <strong id="cantidadVisible">@totalLiquidaciones</strong>
                        de
                        <strong>@totalLiquidaciones</strong>
                        liquidación(es)
                    </div>

                </div>

            </div>

        </div>

        <div class="card-body">

            <div class="table-responsive">

                <table class="table table-hover align-middle mb-0">

                    <thead class="table-light">
                        <tr>
                            <th>#</th>
                            <th>Empleado</th>
                            <th>Solicitud</th>
                            <th>Destino</th>
                            <th>Periodo</th>
                            <th>Fecha de creación</th>
                            <th>Total</th>
                            <th>Saldo</th>
                            <th>Estado</th>
                            <th class="text-end">Acciones</th>
                        </tr>
                    </thead>

                    <tbody id="tablaLiquidaciones">

                        @if (Model != null && Model.Any())
                        {
                            foreach (var item in Model)
                            {
                                var nombreCompleto =
                                $"{item.Usuario?.Nombres} {item.Usuario?.Apellidos}".Trim();

                                var correo =
                                item.Usuario?.Correo ?? string.Empty;

                                var destino =
                                item.Solicitud?.Destino ?? string.Empty;

                                var reembolso =
                                reembolsos.FirstOrDefault(r =>
                                r.IdRendicion == item.IdRendicion);

                                var tieneReembolsoPendiente =
                                reembolso != null &&
                                reembolso.IdEstadoReembolso == 2;

                                var reembolsoPagado =
                                reembolso != null &&
                                reembolso.IdEstadoReembolso == 3;

                                var estadoFiltro =
                                tieneReembolsoPendiente
                                ? "reembolso"
                                : item.IdEstadoRendicion.ToString();

                                var textoBusqueda =
                                $"{item.IdRendicion} " +
                                $"{item.IdSolicitud} " +
                                $"{nombreCompleto} " +
                                $"{correo} " +
                                $"{destino} " +
                                $"{(tieneReembolsoPendiente ? "reembolso pendiente" : "")}";

                                <tr data-estado="@estadoFiltro"
                                    data-busqueda="@textoBusqueda.ToLowerInvariant()">

                                    <td>
                                        <strong>#@item.IdRendicion</strong>
                                    </td>

                                    <td>
                                        <strong>
                                            @(string.IsNullOrWhiteSpace(nombreCompleto)
                                                ? "Sin empleado"
                                                : nombreCompleto)
                                        </strong>

                                        @if (!string.IsNullOrWhiteSpace(correo))
                                        {
                                            <br />

                                            <small class="text-muted">
                                                @correo
                                            </small>
                                        }
                                    </td>

                                    <td>
                                        #@item.IdSolicitud
                                    </td>

                                    <td>
                                        @(string.IsNullOrWhiteSpace(destino)
                                            ? "-"
                                            : destino)
                                    </td>

                                    <td>
                                        @item.FechaInicio.ToString("dd/MM/yyyy")

                                        <br />

                                        <small class="text-muted">
                                            hasta @item.FechaFin.ToString("dd/MM/yyyy")
                                        </small>
                                    </td>

                                    <td>
                                        @item.Fecha.ToString("dd/MM/yyyy")
                                    </td>

                                    <td>
                                        <strong>
                                            S/ @item.Total.ToString("N2")
                                        </strong>
                                    </td>

                                    <td>
                                        S/ @item.Saldo.ToString("N2")
                                    </td>

                                    <td>
                                        @switch (item.IdEstadoRendicion)
                                        {
                                            case 1:
                                                <span class="estado estado-proceso">
                                                    <i class="bi bi-pencil-square"></i>
                                                    En proceso
                                                </span>
                                                break;

                                            case 2:
                                                <span class="estado estado-pendiente">
                                                    <i class="bi bi-clock-fill"></i>
                                                    Pendiente de revisión
                                                </span>
                                                break;

                                            case 3:
                                                @if (tieneReembolsoPendiente)
                                                {
                                                    <span class="estado estado-reembolso">
                                                        <i class="bi bi-cash-coin"></i>
                                                        Aprobada - reembolso pendiente
                                                    </span>
                                                }
                                                else if (reembolsoPagado)
                                                {
                                                    <span class="estado estado-pagado">
                                                        <i class="bi bi-check-circle-fill"></i>
                                                        Aprobada - reembolso pagado
                                                    </span>
                                                }
                                                else
                                                {
                                                    <span class="estado estado-aprobada">
                                                        <i class="bi bi-check-circle-fill"></i>
                                                        Aprobada
                                                    </span>
                                                }
                                                break;

                                            case 4:
                                                <span class="estado estado-rechazada">
                                                    <i class="bi bi-x-circle-fill"></i>
                                                    Rechazada
                                                </span>
                                                break;

                                            default:
                                                <span class="estado bg-secondary text-white">
                                                    Sin estado
                                                </span>
                                                break;
                                        }
                                    </td>

                                    <td>
                                        <div class="acciones">

                                            @if (item.IdEstadoRendicion == 1)
                                            {
                                                <span class="accion-proceso">
                                                    <i class="bi bi-hourglass-split"></i>
                                                    En elaboración
                                                </span>
                                            }
                                            else if (item.IdEstadoRendicion == 2)
                                            {
                                                <a asp-controller="Rendicion"
                                                   asp-action="DetalleAdmin"
                                                   asp-route-id="@item.IdRendicion"
                                                   class="btn btn-warning btn-sm">
                                                    <i class="bi bi-search"></i>
                                                    Revisar
                                                </a>
                                            }
                                            else if (tieneReembolsoPendiente)
                                            {
                                                <a asp-controller="Rendicion"
                                                   asp-action="DetalleAdmin"
                                                   asp-route-id="@item.IdRendicion"
                                                   class="btn btn-primary btn-sm">
                                                    <i class="bi bi-cash-coin"></i>
                                                    Registrar reembolso
                                                </a>
                                            }
                                            else
                                            {
                                                <a asp-controller="Rendicion"
                                                   asp-action="DetalleAdmin"
                                                   asp-route-id="@item.IdRendicion"
                                                   class="btn btn-outline-primary btn-sm">
                                                    <i class="bi bi-eye"></i>
                                                    Ver detalle
                                                </a>
                                            }

                                            @if (!string.IsNullOrWhiteSpace(item.ArchivoPdf))
                                            {
                                                <a href="@item.ArchivoPdf"
                                                   target="_blank"
                                                   rel="noopener"
                                                   class="btn btn-outline-danger btn-sm">
                                                    <i class="bi bi-file-earmark-pdf"></i>
                                                    PDF
                                                </a>
                                            }

                                        </div>
                                    </td>

                                </tr>
                            }
                        }
                        else
                        {
                            <tr id="filaSinRegistros">
                                <td colspan="10"
                                    class="text-center text-muted py-5">

                                    <i class="bi bi-inbox fs-2 d-block mb-2"></i>
                                    No hay liquidaciones registradas.

                                </td>
                            </tr>
                        }

                        <tr id="filaSinResultados"
                            style="display:none;">

                            <td colspan="10"
                                class="text-center text-muted py-5">

                                <i class="bi bi-search fs-2 d-block mb-2"></i>
                                No se encontraron liquidaciones con los criterios seleccionados.

                            </td>

                        </tr>

                    </tbody>

                </table>

            </div>

        </div>

    </div>

    <div class="mt-4">
        <a asp-controller="Principal"
           asp-action="Index"
           class="btn btn-secondary">
            <i class="bi bi-arrow-left"></i>
            Regresar
        </a>
    </div>

</div>

<script>
    document.addEventListener("DOMContentLoaded", function () {

        const botones =
            document.querySelectorAll(".filtro-btn");

        const filas =
            document.querySelectorAll(
                "#tablaLiquidaciones tr[data-estado]"
            );

        const buscador =
            document.getElementById("buscarLiquidacion");

        const filaSinResultados =
            document.getElementById("filaSinResultados");

        const cantidadVisible =
            document.getElementById("cantidadVisible");

        let estadoSeleccionado = "todos";

        function normalizarTexto(texto) {
            return (texto || "")
                .toLowerCase()
                .normalize("NFD")
                .replace(/[\u0300-\u036f]/g, "")
                .trim();
        }

        function aplicarFiltros() {

            const termino =
                normalizarTexto(buscador?.value);

            let visibles = 0;

            filas.forEach(function (fila) {

                const coincideEstado =
                    estadoSeleccionado === "todos" ||
                    fila.dataset.estado === estadoSeleccionado;

                const textoFila =
                    normalizarTexto(fila.dataset.busqueda);

                const coincideBusqueda =
                    !termino ||
                    textoFila.includes(termino);

                const mostrar =
                    coincideEstado && coincideBusqueda;

                fila.style.display =
                    mostrar ? "" : "none";

                if (mostrar) {
                    visibles++;
                }
            });

            if (filaSinResultados) {
                filaSinResultados.style.display =
                    filas.length > 0 && visibles === 0
                        ? ""
                        : "none";
            }

            if (cantidadVisible) {
                cantidadVisible.textContent =
                    visibles.toString();
            }
        }

        botones.forEach(function (boton) {

            boton.addEventListener("click", function () {

                botones.forEach(function (item) {
                    item.classList.remove("active");
                });

                boton.classList.add("active");

                estadoSeleccionado =
                    boton.dataset.estado || "todos";

                aplicarFiltros();
            });
        });

        buscador?.addEventListener(
            "input",
            aplicarFiltros
        );

        aplicarFiltros();
    });
</script>
