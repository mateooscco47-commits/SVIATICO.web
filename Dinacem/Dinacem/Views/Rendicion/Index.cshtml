@model List<Dinacem.Models.Solicitud>

@{
    ViewData["Title"] = "Rendición de Gastos";
    Layout = "~/Views/Shared/_LayoutEmpleado.cshtml";

    var rendiciones = ViewBag.Rendiciones as List<Dinacem.Models.Rendicion>;
}

<div class="container mt-5">

    <div class="card shadow">

        <div class="card-header bg-primary text-white">
            <h3>Rendición de Gastos</h3>
        </div>

        <div class="card-body">

            <p class="text-muted">
                Seleccione una solicitud aprobada para comenzar o continuar la rendición de gastos.
            </p>

            @if (TempData["mensaje"] != null)
            {
                <div class="alert alert-success">
                    @TempData["mensaje"]
                </div>
            }

            @if (TempData["error"] != null)
            {
                <div class="alert alert-danger">
                    @TempData["error"]
                </div>
            }

            @if (Model == null || Model.Count == 0)
            {
                <div class="alert alert-warning">
                    No tiene solicitudes aprobadas para realizar una rendición.
                </div>
            }
            else
            {
                <table class="table table-hover table-bordered align-middle">
                    <thead class="table-dark">
                        <tr>
                            <th>Solicitud</th>
                            <th>Fecha</th>
                            <th>Destino</th>
                            <th>Monto Aprobado</th>
                            <th>Estado Rendición</th>
                            <th>Acción</th>
                        </tr>
                    </thead>

                    <tbody>
                        @foreach (var item in Model)
                        {
                            var rendicionExistente = rendiciones?
                            .FirstOrDefault(r => r.IdSolicitud == item.IdSolicitud);

                            <tr>
                                <td>@item.IdSolicitud</td>
                                <td>@item.Fecha.ToString("dd/MM/yyyy")</td>
                                <td>@item.Destino</td>
                                <td>S/. @item.Monto.ToString("N2")</td>

                                <td>
                                    @if (rendicionExistente == null)
                                    {
                                        <span class="badge bg-secondary">Sin rendición</span>
                                    }
                                    else if (rendicionExistente.IdEstadoRendicion == 1)
                                    {
                                        <span class="badge bg-primary">En proceso</span>
                                    }
                                    else if (rendicionExistente.IdEstadoRendicion == 2)
                                    {
                                        <span class="badge bg-warning text-dark">Pendiente de revisión</span>
                                    }
                                    else if (rendicionExistente.IdEstadoRendicion == 3)
                                    {
                                        <span class="badge bg-success">Aprobada</span>
                                    }
                                    else if (rendicionExistente.IdEstadoRendicion == 4)
                                    {
                                        <span class="badge bg-danger">Rechazada</span>
                                    }
                                </td>

                                <td>
                                    @if (rendicionExistente == null)
                                    {
                                        <a asp-action="Create"
                                           asp-route-idSolicitud="@item.IdSolicitud"
                                           class="btn btn-success btn-sm">
                                            Crear Rendición
                                        </a>
                                    }
                                    else if (rendicionExistente.IdEstadoRendicion == 1)
                                    {
                                        <a asp-controller="Gasto"
                                           asp-action="Index"
                                           asp-route-idRendicion="@rendicionExistente.IdRendicion"
                                           class="btn btn-warning btn-sm">
                                            Continuar Rendición
                                        </a>
                                    }
                                    else
                                    {
                                        <a asp-controller="Rendicion"
                                           asp-action="DetalleEmpleado"
                                           asp-route-id="@rendicionExistente.IdRendicion"
                                           class="btn btn-secondary btn-sm">
                                            Ver Detalle
                                        </a>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }

            <div class="mt-3">
                <a asp-controller="Empleado"
                   asp-action="Index"
                   class="btn btn-secondary">
                    Volver
                </a>
            </div>

        </div>
    </div>
</div>