@model List<Dinacem.Models.Rendicion>

@{
    ViewData["Title"] = "Mis Rendiciones";
    Layout = "~/Views/Shared/_LayoutEmpleado.cshtml";
}

<style>
    .card-rendiciones {
        border: 0;
        border-radius: 14px;
        box-shadow: 0 4px 14px rgba(15, 23, 42, 0.08);
    }

    .page-title {
        color: #0f172a;
        font-weight: 800;
    }

    .table th {
        font-size: 12px;
        text-transform: uppercase;
        color: #64748b;
        white-space: nowrap;
    }

    .table td {
        vertical-align: middle;
    }

    .estado {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 7px 12px;
        border-radius: 20px;
        font-size: 12px;
        font-weight: 700;
        white-space: nowrap;
    }

    .estado-proceso {
        background: #dbeafe;
        color: #1d4ed8;
        border: 1px solid #93c5fd;
    }

    .estado-pendiente {
        background: #fef3c7;
        color: #92400e;
        border: 1px solid #fcd34d;
    }

    .estado-aprobada {
        background: #dcfce7;
        color: #166534;
        border: 1px solid #86efac;
    }

    .estado-rechazada {
        background: #fee2e2;
        color: #991b1b;
        border: 1px solid #fca5a5;
    }

    .acciones {
        display: flex;
        flex-wrap: wrap;
        gap: 6px;
    }
</style>

<div class="container-fluid">

    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-4">

        <div>
            <h2 class="page-title mb-1">
                <i class="bi bi-receipt-cutoff me-2"></i>
                Mis Rendiciones
            </h2>

            <p class="text-muted mb-0">
                Consulte el estado, continúe una rendición en proceso o descargue su liquidación.
            </p>
        </div>

        <a asp-controller="Empleado"
           asp-action="Index"
           class="btn btn-outline-secondary mt-3 mt-md-0">

            <i class="bi bi-arrow-left"></i>
            Volver

        </a>

    </div>

    @if (TempData["mensaje"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">

            @TempData["mensaje"]

            <button type="button"
                    class="btn-close"
                    data-bs-dismiss="alert"
                    aria-label="Cerrar">
            </button>

        </div>
    }

    @if (TempData["error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show">

            @Html.Raw(TempData["error"])

            <button type="button"
                    class="btn-close"
                    data-bs-dismiss="alert"
                    aria-label="Cerrar">
            </button>

        </div>
    }

    <div class="card card-rendiciones">

        <div class="card-header bg-primary text-white py-3">

            <h5 class="mb-0">
                Historial de rendiciones
            </h5>

        </div>

        <div class="card-body">

            <div class="table-responsive">

                <table class="table table-hover table-bordered align-middle mb-0">

                    <thead class="table-light">

                        <tr>
                            <th>#</th>
                            <th>Solicitud</th>
                            <th>Destino</th>
                            <th>Periodo</th>
                            <th>Fecha de creación</th>
                            <th>Total gastado</th>
                            <th>Saldo</th>
                            <th>Estado</th>
                            <th style="min-width:280px;">Acciones</th>
                        </tr>

                    </thead>

                    <tbody>

                        @if (Model != null && Model.Any())
                        {
                            foreach (var item in Model)
                            {
                                <tr>

                                    <td>
                                        <strong>
                                            #@item.IdRendicion
                                        </strong>
                                    </td>

                                    <td>
                                        #@item.IdSolicitud
                                    </td>

                                    <td>
                                        @(item.Solicitud?.Destino ?? "-")
                                    </td>

                                    <td>
                                        @item.FechaInicio.ToString("dd/MM/yyyy")

                                        <br />

                                        <small class="text-muted">
                                            hasta @item.FechaFin.ToString("dd/MM/yyyy")
                                        </small>
                                    </td>

                                    <td>
                                        @item.Fecha.ToString("dd/MM/yyyy")
                                    </td>

                                    <td>
                                        <strong>
                                            S/ @item.Total.ToString("N2")
                                        </strong>
                                    </td>

                                    <td>
                                        S/ @item.Saldo.ToString("N2")
                                    </td>

                                    <td>

                                        @switch (item.IdEstadoRendicion)
                                        {
                                            case 1:
                                                <span class="estado estado-proceso">
                                                    <i class="bi bi-pencil-square"></i>
                                                    En proceso
                                                </span>
                                                break;

                                            case 2:
                                                <span class="estado estado-pendiente">
                                                    <i class="bi bi-clock-fill"></i>
                                                    Pendiente de revisión
                                                </span>
                                                break;

                                            case 3:
                                                <span class="estado estado-aprobada">
                                                    <i class="bi bi-check-circle-fill"></i>
                                                    Aprobada
                                                </span>
                                                break;

                                            case 4:
                                                <span class="estado estado-rechazada">
                                                    <i class="bi bi-x-circle-fill"></i>
                                                    Rechazada
                                                </span>
                                                break;

                                            default:
                                                <span class="estado bg-secondary text-white">
                                                    Sin estado
                                                </span>
                                                break;
                                        }

                                    </td>

                                    <td>

                                        <div class="acciones">

                                            @if (item.IdEstadoRendicion == 1)
                                            {
                                                <a asp-controller="Gasto"
                                                   asp-action="Index"
                                                   asp-route-idRendicion="@item.IdRendicion"
                                                   class="btn btn-primary btn-sm">

                                                    <i class="bi bi-pencil-square"></i>
                                                    Continuar

                                                </a>
                                            }

                                            <a asp-controller="Rendicion"
                                               asp-action="DetalleEmpleado"
                                               asp-route-id="@item.IdRendicion"
                                               class="btn btn-outline-secondary btn-sm">

                                                <i class="bi bi-eye"></i>
                                                Ver detalle

                                            </a>

                                            @if (!string.IsNullOrWhiteSpace(item.ArchivoPdf))
                                            {
                                                <a href="@item.ArchivoPdf"
                                                   target="_blank"
                                                   rel="noopener"
                                                   class="btn btn-outline-danger btn-sm">

                                                    <i class="bi bi-file-earmark-pdf"></i>
                                                    Ver PDF

                                                </a>
                                            }

                                        </div>

                                    </td>

                                </tr>
                            }
                        }
                        else
                        {
                            <tr>

                                <td colspan="9"
                                    class="text-center text-muted py-5">

                                    <i class="bi bi-inbox fs-2 d-block mb-2"></i>

                                    No tienes rendiciones registradas.

                                </td>

                            </tr>
                        }

                    </tbody>

                </table>

            </div>

        </div>

    </div>

</div>